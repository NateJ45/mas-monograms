{
  "name": "mas-monograms",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:full": "npm run typegen && astro build",
    "preview": "wrangler dev",
    "astro": "astro",
    "deploy": "npm run build && wrangler deploy",
    "generate-types": "wrangler types",
    "typegen": "npm --prefix studio run typegen",
    "og": "node scripts/generate-og-default.mjs",
    "og:pages": "node scripts/generate-og-pages.mjs",
    "apply-brand": "node scripts/apply-brand.mjs",
    "llms:full": "node scripts/generate-llms-full.mjs",
    "studio:dev": "npm --prefix studio run dev",
    "studio:deploy": "npm --prefix studio run deploy",
    "studio:import": "node scripts/import-content.mjs",
    "seed": "node scripts/seed-core.mjs",
    "lighthouse": "npm run build && npx lhci autorun",
    "test": "node --experimental-strip-types --test src/lib/*.test.ts scripts/lib/*.test.mjs",
    "check": "npm run typegen && npm run build && npm --prefix studio run build && npm test",
    "lint": "eslint src/**/*.{ts,tsx,astro} scripts/**/*.mjs",
    "lint:fix": "eslint --fix src/**/*.{ts,tsx,astro} scripts/**/*.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.5.5",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/work-sans": "^5.2.8",
    "@portabletext/react": "^6.2.0",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@tabler/icons": "^3.44.0",
    "@tabler/icons-react": "^3.44.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "primereact": "^10.9.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-photo-album": "^3.6.0",
    "resend": "^4.0.0",
    "shadcn": "^4.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.95.0",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "opentype.js": "^2.0.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
