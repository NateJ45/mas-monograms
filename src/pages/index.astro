---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import StatsRow from '@/components/StatsRow.astro';
import ProcessStep from '@/components/ProcessStep.astro';
import ComboPreviewSection from '@/components/ComboPreviewSection.astro';
import SanityImage from '@/components/SanityImage.astro';
import PortableText from '@/components/PortableText';
import CtaBanner from '@/components/CtaBanner.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import { urlFor } from '@/lib/sanity';
import {
  getSiteSettings,
  getHomePage,
  getAllItemCategories,
  getPopularCombinations,
  getFeaturedGalleryItems,
  getAllFonts,
  getAllThreadColors,
} from '@/lib/queries';

const [siteSettings, page, categories, combos, galleryItems, allFonts, allThreadColors] = await Promise.all([
  getSiteSettings(),
  getHomePage(),
  getAllItemCategories(),
  getPopularCombinations(),
  getFeaturedGalleryItems(9),
  getAllFonts(),
  getAllThreadColors(),
]);

// ComboPreview data: real categories/fonts/colors, curated to a small,
// visually varied set. Fonts filtered to ones with an actual specimen photo
// (10 of 18 have none — see docs/superpowers/specs/2026-07-01-combo-preview-design.md).
// "Bring Your Own Item" is excluded — you can't preview a font/thread
// pairing on an item that hasn't been specified, unlike every other
// category here.
const comboCategories = (categories ?? [])
  .filter((c: any) => c.slug?.current !== 'bring-your-own-item')
  .slice(0, 8)
  .map((c: any) => ({
    name: c.name,
    slug: c.slug?.current ?? '',
  }));
const comboFonts = (allFonts ?? [])
  .filter((f: any) => f.previewImage?.asset)
  .slice(0, 6)
  .map((f: any) => ({
    name: f.name,
    // 600px covers the enlarged specimen in the preview card; the 28px picker
    // thumbnails just downscale from the same URL.
    previewUrl: urlFor(f.previewImage).width(600).auto('format').url(),
    alt: f.previewImage.alt ?? f.name,
  }));
// One color per family for visual variety, in a fixed, real, verified order
// (all 8 names confirmed present in the live threadColor catalog from Plan 2).
const COMBO_THREAD_NAMES = ['Navy', 'Forest Green', 'True Red', 'Purple', 'Bright Gold', 'Charcoal', 'Bright White', 'Bronze'];
const comboThreadColors = COMBO_THREAD_NAMES
  .map((name) => (allThreadColors ?? []).find((c: any) => c.name === name))
  .filter((c: any) => !!c)
  .map((c: any) => ({ name: c.name, hex: c.hexColor }));

const title       = page?.seoTitle       ?? siteSettings?.seoTitle ?? 'MAS Monograms — Custom Embroidery in St. Matthews, SC';
const description = page?.seoDescription ?? siteSettings?.seoDescription ?? 'Hand-embroidered monograms and personalized gifts by Mary Ann Stone. Quality custom embroidery on towels, bags, shirts, baby items, and more.';

// Hero images for carousel/slideshow.
// No dedicated hero images are set on homePage (and none are coming), so the
// hero would otherwise render as an empty text-only band. Instead, reuse the
// real featured gallery photos as the hero background — the same image-hero +
// dark-scrim treatment the category pages use (see [slug].astro), which reads
// far better than an empty parchment void. Each galleryItem's `image` object is
// the same SanityImageObject shape Hero/HeroBackground expect (asset + alt).
const authoredHeroImages = (page?.heroImages ?? []).filter((img: any) => img?.asset);
const galleryHeroImages = (galleryItems ?? [])
  .map((item: any) => item.image)
  .filter((img: any) => img?.asset);
// Prefer authored hero images if an editor ever adds them; otherwise fall back
// to the featured gallery work so the hero always shows real embroidery.
const heroImages = authoredHeroImages.length > 0 ? authoredHeroImages : galleryHeroImages;
---

<BaseLayout {title} {description} seoImage={page?.seoImage ?? siteSettings?.seoImage} {siteSettings}>

  {/* ── Hero ──────────────────────────────────────────────────────────────── */}
  <Hero
    eyebrow={page?.heroEyebrow}
    headline={page?.heroHeadline ?? 'Custom Embroidery'}
    headlineItalicSuffix={page?.heroItalicWord}
    subhead={page?.heroSubhead}
    backgroundImages={heroImages}
    primaryCta={page?.heroPrimaryCtaLabel ? { label: page.heroPrimaryCtaLabel, href: page.heroPrimaryCtaHref ?? '/request-a-quote' } : null}
    secondaryCta={page?.heroSecondaryCtaLabel ? { label: page.heroSecondaryCtaLabel, href: page.heroSecondaryCtaHref ?? '/how-it-works' } : null}
    headingId="hero-heading"
    layout="split"
  />

  {/* ── Trust Bar ─────────────────────────────────────────────────────────── */}
  {(page?.trustItems ?? []).length > 0 && (
    <section class="bg-primary py-m">
      <div class="mx-auto max-w-content px-m">
        {page?.trustHeadline && (
          <p class="text-xs uppercase tracking-eyebrow text-white/70 text-center mb-s">{page.trustHeadline}</p>
        )}
        <ul class="flex flex-wrap justify-center gap-l list-none">
          {(page.trustItems as string[]).map((item: string) => (
            <li class="text-sm text-white/90 flex items-center gap-xs">
              <span class="text-white/50" aria-hidden="true">✦</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ── Stats Strip ───────────────────────────────────────────────────────── */}
  <StatsRow stats={page?.statsItems ?? []} />

  {/* ── Category Grid ─────────────────────────────────────────────────────── */}
  {categories.length > 0 && (
    <section class="py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <div class="text-center mb-l" data-reveal>
          {page?.categoriesEyebrow && (
            <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.categoriesEyebrow}</p>
          )}
          <h2 class="font-display text-h2 text-foreground">{page?.categoriesHeadline ?? 'Shop by Item'}</h2>
          {page?.categoriesSubhead && (
            <p class="text-[var(--color-text-secondary)] mt-s max-w-xl mx-auto">{page.categoriesSubhead}</p>
          )}
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-m" data-stagger-grid>
          {categories.slice(0, 8).map((cat: any) => (
            <CategoryCard name={cat.name} slug={cat.slug?.current ?? ''} cardImage={cat.cardImage} />
          ))}
        </div>
        <div class="text-center mt-l">
          <a href="/shop-by-item" class="inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link hover:text-primary-dark transition-colors">
            View all items <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <ComboPreviewSection
    categories={comboCategories}
    fonts={comboFonts}
    threadColors={comboThreadColors}
    eyebrow={page?.comboPreviewEyebrow}
    headline={page?.comboPreviewHeadline}
    subhead={page?.comboPreviewSubhead}
  />

  {/* ── About / Maker ─────────────────────────────────────────────────────── */}
  {(page?.aboutHeadline || page?.aboutBody) && (
    <section class="bg-tertiary py-section-lg">
      <div class="mx-auto max-w-content px-m grid grid-cols-1 lg:grid-cols-2 gap-section-md items-center">
        {page?.aboutPhoto?.asset && (
          <div class="relative rounded-2xl overflow-hidden shadow-xl order-last lg:order-first" data-reveal>
            <SanityImage
              source={page.aboutPhoto}
              width={700}
              sizes="(max-width: 1024px) 100vw, 50vw"
              class="w-full h-auto object-cover"
            />
          </div>
        )}
        <div data-reveal>
          {page?.aboutEyebrow && (
            <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.aboutEyebrow}</p>
          )}
          <h2 class="font-display text-h2 text-foreground mb-m leading-headline-tight">
            {page.aboutHeadline}
          </h2>
          {page?.aboutBody && (
            <div class="text-[var(--color-text-secondary)] mb-l">
              <PortableText client:idle value={page.aboutBody} />
            </div>
          )}
          {page?.aboutCtaLabel && (
            <a
              href={page.aboutCtaHref ?? '/about'}
              class="inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link hover:text-primary-dark transition-colors"
            >
              {page.aboutCtaLabel} <span aria-hidden="true">→</span>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  {/* ── Process ───────────────────────────────────────────────────────────── */}
  {(page?.processSteps ?? []).length > 0 && (
    <section class="py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <div class="text-center mb-l" data-reveal>
          {page?.processEyebrow && (
            <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.processEyebrow}</p>
          )}
          <h2 class="font-display text-h2 text-foreground">{page?.processHeadline ?? 'How It Works'}</h2>
          {page?.processSubhead && (
            <p class="text-[var(--color-text-secondary)] mt-s max-w-xl mx-auto">{page.processSubhead}</p>
          )}
        </div>
        <ol class="grid grid-cols-2 lg:grid-cols-4 gap-l mt-l list-none" data-stagger-grid>
          {(page.processSteps as any[]).map((step: any, i: number) => (
            <li class="h-full">
              <ProcessStep
                step={{
                  stepNumber: parseInt(step.number, 10) || i + 1,
                  title: step.label,
                  shortDescription: step.body,
                }}
                variant="preview"
                isLast={i === (page.processSteps as any[]).length - 1}
              />
            </li>
          ))}
        </ol>
        {page?.processCtaLabel && (
          <div class="text-center mt-l">
            <a
              href={page.processCtaHref ?? '/how-it-works'}
              class="inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link hover:text-primary-dark transition-colors"
            >
              {page.processCtaLabel} <span aria-hidden="true">→</span>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  {/* ── Popular Combinations ──────────────────────────────────────────────── */}
  {combos.length > 0 && (
    <section class="bg-tertiary py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <div class="text-center mb-l" data-reveal>
          {page?.combosEyebrow && (
            <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.combosEyebrow}</p>
          )}
          <h2 class="font-display text-h2 text-foreground">{page?.combosHeadline ?? 'Popular Combinations'}</h2>
          {page?.combosSubhead && (
            <p class="text-[var(--color-text-secondary)] mt-s max-w-xl mx-auto">{page.combosSubhead}</p>
          )}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-l" data-stagger-grid>
          {combos.slice(0, 6).map((combo: any) => (
            <div class="card-lift group bg-background rounded-xl overflow-hidden">
              {combo.image?.asset ? (
                <div class="aspect-[4/3] p-1 bg-secondary">
                  <div class="relative w-full h-full overflow-hidden rounded-[calc(var(--radius-xl)-0.25rem)] img-zoom">
                    <SanityImage
                      source={combo.image}
                      width={600}
                      height={450}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                      class="w-full h-full object-cover"
                    />
                    <div class="img-tint" aria-hidden="true"></div>
                  </div>
                </div>
              ) : (
                /* No-photo "recipe" card: the combination's REAL font specimen on
                   a Paper ground inside the hoop-ring frame, with a band of the
                   REAL thread colour along the bottom. Each card differs by its
                   specimen + thread colour (that's the whole point). Falls back
                   to the name in the monogram script if a font has no specimen. */
                <div class="aspect-[4/3] p-1 bg-secondary">
                  <div class="relative w-full h-full overflow-hidden rounded-[calc(var(--radius-xl)-0.25rem)] bg-card flex items-center justify-center p-m">
                    {combo.font?.previewImage?.asset ? (
                      <SanityImage
                        source={combo.font.previewImage}
                        width={360}
                        height={270}
                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                        class="w-full h-full object-contain"
                      />
                    ) : (
                      <p class="font-monogram text-primary leading-none text-[clamp(2.25rem,5vw,3.25rem)]">
                        {combo.name}
                      </p>
                    )}
                    {combo.threadColor?.hexColor && (
                      <div
                        class="absolute inset-x-0 bottom-0 h-2.5"
                        style={`background-color: ${combo.threadColor.hexColor};`}
                        aria-hidden="true"
                      ></div>
                    )}
                  </div>
                </div>
              )}
              <div class="p-m">
                <h3 class="font-display text-h4 text-foreground mb-xs">{combo.name}</h3>
                {combo.description && <p class="text-sm text-[var(--color-text-secondary)]">{combo.description}</p>}
                {(combo.threadColor?.name || combo.font?.name) && (
                  <p class="flex items-center gap-xs text-xs text-[var(--color-text-secondary)] mt-s">
                    {combo.threadColor?.hexColor && (
                      <span
                        class="inline-block w-3.5 h-3.5 rounded-full border border-border shrink-0"
                        style={`background-color: ${combo.threadColor.hexColor};`}
                        aria-hidden="true"
                      ></span>
                    )}
                    <span>
                      {combo.threadColor?.name}{combo.threadColor?.name && combo.font?.name ? ' · ' : ''}{combo.font?.name}
                    </span>
                  </p>
                )}
                {(combo.tags ?? []).length > 0 && (
                  <div class="flex flex-wrap gap-xs mt-s">
                    {(combo.tags as string[]).map((tag: string) => (
                      <span class="text-xs px-s py-0.5 rounded-full bg-tertiary text-[var(--color-text-secondary)]">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Testimonials section removed 2026-07-02 — Mary Ann has no real reviews to
      publish yet, and we don't invent them. Re-add when genuine ones exist. */}

  {/* ── Gallery Preview ───────────────────────────────────────────────────── */}
  {galleryItems.length > 0 && (
    <section class="bg-tertiary py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <div class="text-center mb-l" data-reveal>
          {page?.galleryEyebrow && (
            <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.galleryEyebrow}</p>
          )}
          <h2 class="font-display text-h2 text-foreground">{page?.galleryHeadline ?? 'From the Studio'}</h2>
          {page?.gallerySubhead && (
            <p class="text-[var(--color-text-secondary)] mt-s max-w-xl mx-auto">{page.gallerySubhead}</p>
          )}
        </div>
        <div class="columns-2 sm:columns-3 lg:columns-4 gap-m space-y-m">
          {galleryItems.map((item: any) => (
            item.image?.asset && (
              <div class="group break-inside-avoid rounded-xl overflow-hidden p-1 bg-secondary">
                <div class="relative overflow-hidden rounded-[calc(var(--radius-xl)-0.25rem)] img-zoom">
                  <SanityImage
                    source={item.image}
                    width={400}
                    sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                    class="w-full h-auto"
                  />
                  <div class="img-tint" aria-hidden="true"></div>
                </div>
              </div>
            )
          ))}
        </div>
        {page?.galleryCtaLabel && (
          <div class="text-center mt-l">
            <a
              href={page.galleryCtaHref ?? '/style-gallery'}
              class="inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link hover:text-primary-dark transition-colors"
            >
              {page.galleryCtaLabel} <span aria-hidden="true">→</span>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <CtaBanner
    eyebrow={page?.ctaEyebrow}
    headline={page?.ctaHeadline}
    subhead={page?.ctaSubhead}
    ctaLabel={page?.ctaLabel}
    ctaHref={page?.ctaHref}
  />
</BaseLayout>
