---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SanityImage from '@/components/SanityImage.astro';
import PortableText from '@/components/PortableText';
import CtaBanner from '@/components/CtaBanner.astro';
import { getSiteSettings, getAboutPage, getFeaturedGalleryItems } from '@/lib/queries';

const [siteSettings, page, recentWork] = await Promise.all([
  getSiteSettings(),
  getAboutPage(),
  getFeaturedGalleryItems(3),
]);

// The About page has no portrait (deliberately absent), so it can read as an
// imagery void. Fill it with real work that already exists — up to three
// featured gallery photos, frameless (Direction C imagery grammar).
const recentWorkPhotos = (recentWork ?? []).filter((item: any) => item?.image?.asset).slice(0, 3);
const recentWorkHeadline = page?.recentWorkHeadline ?? 'Recent work from the studio';

const title       = page?.seoTitle       ?? 'About — MAS Monograms';
const description = page?.seoDescription ?? 'Meet Mary Ann Stone, the maker behind MAS Monograms. One-woman embroidery studio in St. Matthews, SC.';
---

<BaseLayout {title} {description} seoImage={page?.seoImage} {siteSettings}>

  {/* Hero. The two-column grid only exists when Sanity has a heroImage —
      without one, reserving the right half stranded the headline against a
      screen-wide void (the "accidental empty space" problem). Centered text
      is the composed no-photo fallback, matching the other interior heroes. */}
  <section class="bg-tertiary py-section-lg">
    <div
      class:list={[
        'mx-auto max-w-content px-m',
        page?.heroImage?.asset
          ? 'grid grid-cols-1 lg:grid-cols-2 gap-section-md items-center'
          : 'text-center',
      ]}
    >
      <div class:list={[!page?.heroImage?.asset && 'max-w-2xl mx-auto']}>
        {page?.heroEyebrow && (
          <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.heroEyebrow}</p>
        )}
        <h1 class="font-display text-h1 text-foreground leading-headline-tight mb-m">
          {page?.heroHeadline ?? 'About MAS Monograms'}
        </h1>
        {page?.heroSubhead && (
          <p class:list={['text-[var(--color-text-secondary)] max-w-xl', !page?.heroImage?.asset && 'mx-auto']}>{page.heroSubhead}</p>
        )}
      </div>
      {page?.heroImage?.asset && (
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <SanityImage
            source={page.heroImage}
            width={700}
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="w-full h-auto object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}
    </div>
  </section>

  {/* Story — photo-optional. With a makerPhoto it's a two-column layout;
      without one (current state) the prose runs as a single centered column
      instead of stranding in a half-width block. The signed maker
      attribution renders beneath the prose in BOTH cases so the
      "Mary Ann Stone · Founder" signature always shows. */}
  {(page?.storyContent || page?.makerPhoto) && (
    <section class="py-section-lg">
      <div
        class:list={[
          'mx-auto max-w-content px-m',
          page?.makerPhoto?.asset
            ? 'grid grid-cols-1 lg:grid-cols-2 gap-section-md items-start'
            : '',
        ]}
      >
        {page?.makerPhoto?.asset && (
          <div class="relative">
            <div class="rounded-2xl overflow-hidden">
              <SanityImage
                source={page.makerPhoto}
                width={700}
                sizes="(max-width: 1024px) 100vw, 50vw"
                class="w-full h-auto object-cover"
              />
            </div>
          </div>
        )}
        <div class:list={[!page?.makerPhoto?.asset && 'max-w-3xl mx-auto']}>
          {page?.storyHeadline && (
            <h2 class="font-display text-h2 text-foreground mb-m leading-headline-tight">
              {page.storyHeadline}
            </h2>
          )}
          {page?.storyContent && (
            <div class="text-[var(--color-text-secondary)]">
              <PortableText client:idle value={page.storyContent} />
            </div>
          )}
          {page?.makerAttribution && (
            <p class="mt-l font-display italic text-lg text-primary">{page.makerAttribution}</p>
          )}
          {page?.studioNote && (
            <div class="mt-l bg-tertiary rounded-xl p-l">
              <p class="font-display italic text-h4 text-foreground/85">{page.studioNote}</p>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  {/* Recent work strip — real featured gallery photos, frameless. Fills the
      imagery gap on this otherwise text-heavy page using assets that already
      exist (no new photography). */}
  {recentWorkPhotos.length > 0 && (
    <section class="py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <h2 class="font-display text-h2 text-foreground text-center mb-l">
          {recentWorkHeadline}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-m max-w-4xl mx-auto">
          {recentWorkPhotos.map((item: any) => (
            <div>
              <div class="aspect-square overflow-hidden rounded-xl">
                <SanityImage
                  source={item.image}
                  width={500}
                  height={500}
                  sizes="(max-width: 640px) 100vw, 33vw"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Values */}
  {(page?.values ?? []).length > 0 && (
    <section class="bg-tertiary py-section-lg">
      <div class="mx-auto max-w-content px-m">
        {page?.valuesHeadline && (
          <h2 class="font-display text-h2 text-foreground text-center mb-l">
            {page.valuesHeadline}
          </h2>
        )}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-l">
          {(page.values as any[]).map((v: any) => (
            <div class="bg-background rounded-xl border border-border p-l">
              <h3 class="font-display text-h4 text-foreground mb-s">{v.label}</h3>
              <p class="text-[var(--color-text-secondary)]">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Testimonials section removed 2026-07-03 — same placeholder quotes we pulled
      from the homepage. Mary Ann has no real reviews to publish yet, and we don't
      invent them. Re-add when genuine ones exist. */}

  <CtaBanner
    eyebrow={page?.ctaEyebrow}
    headline={page?.ctaHeadline}
    subhead={page?.ctaSubhead}
    ctaLabel={page?.ctaLabel}
    ctaHref={page?.ctaHref}
  />
</BaseLayout>
