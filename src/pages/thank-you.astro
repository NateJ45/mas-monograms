---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SanityImage from '@/components/SanityImage.astro';
import PortableText from '@/components/PortableText';
import { getSiteSettings, getThankYouPage } from '@/lib/queries';

const [siteSettings, page] = await Promise.all([
  getSiteSettings(),
  getThankYouPage(),
]);

const title       = page?.seoTitle       ?? 'Thank You — MAS Monograms';
const description = page?.seoDescription ?? 'Your quote request has been received. Mary Ann will be in touch soon!';
---

<BaseLayout {title} {description} {siteSettings} noindex>
  <section class="min-h-[70vh] py-section-lg flex items-center">
    <div class="mx-auto max-w-content px-m">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-section-md items-center">

        {/* Text */}
        <div data-reveal>
          {page?.eyebrow && (
            <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.eyebrow}</p>
          )}
          <h1 class="font-display text-h1 text-foreground leading-headline-tight mb-m">
            {page?.headline ?? 'Thank You!'}
          </h1>
          {page?.body && (
            <div class="text-foreground/80 mb-l">
              <PortableText client:idle value={page.body} />
            </div>
          )}
          {page?.expectedResponseTime && (
            <div class="bg-tertiary rounded-xl p-m mb-l">
              <p class="text-sm text-foreground/70">
                <strong class="text-foreground">Expected response time:</strong>{' '}
                {page.expectedResponseTime}
              </p>
            </div>
          )}
          {(page?.nextSteps ?? []).length > 0 && (
            <div class="mb-l">
              <p class="text-xs uppercase tracking-eyebrow text-foreground/60 mb-s">What's next</p>
              <ol class="space-y-s list-none">
                {(page.nextSteps as string[]).map((step: string, i: number) => (
                  <li class="flex items-start gap-m">
                    <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary text-white text-xs font-semibold flex items-center justify-center mt-0.5">
                      {i + 1}
                    </span>
                    <span class="text-foreground/80">{step}</span>
                  </li>
                ))}
              </ol>
            </div>
          )}
          {page?.ctaLabel && page?.ctaHref && (
            <a
              href={page.ctaHref}
              class="inline-flex items-center px-l py-m rounded-md bg-primary hover:bg-primary-dark text-white text-sm uppercase tracking-eyebrow font-semibold transition-colors press-tactile"
            >
              {page.ctaLabel}
            </a>
          )}
        </div>

        {/* Image */}
        {page?.image?.asset && (
          <div class="rounded-2xl overflow-hidden shadow-xl" data-reveal>
            <SanityImage
              source={page.image}
              width={700}
              sizes="(max-width: 1024px) 100vw, 50vw"
              class="w-full h-auto object-cover"
              fetchpriority="high"
            />
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
