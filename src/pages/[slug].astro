---
// Dynamic item category pages — one page per itemCategory document.
// Route: /<slug> e.g. /towels, /bags, /shirts
// Built-in routes take precedence over this catch-all.

import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import SanityImage from '@/components/SanityImage.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import CtaLink from '@/components/CtaLink.astro';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { getSiteSettings, getAllItemCategories, getItemCategoryBySlug, getAllGalleryItems } from '@/lib/queries';

export const getStaticPaths: GetStaticPaths = async () => {
  const categories = await getAllItemCategories();
  return (categories ?? [])
    .filter((cat: any) => cat?.slug?.current)
    .map((cat: any) => ({ params: { slug: cat.slug.current } }));
};

const { slug } = Astro.params as { slug: string };

const [siteSettings, category, allGallery, allCategories] = await Promise.all([
  getSiteSettings(),
  getItemCategoryBySlug(slug),
  getAllGalleryItems(),
  getAllItemCategories(),
]);

if (!category) {
  return Astro.redirect('/404', 307);
}

// "Explore Other Items" cross-sell: every OTHER category, ranked by how
// many real gallery photos are tagged to it (categories with more real
// content to show are more useful cross-sell destinations), capped at 3.
const otherCategories = (allCategories ?? [])
  .filter((c: any) => c.slug?.current && c.slug.current !== slug)
  .map((c: any) => ({
    ...c,
    galleryCount: allGallery.filter((item: any) => item.relatedCategory?.slug?.current === c.slug?.current).length,
  }))
  .sort((a: any, b: any) => b.galleryCount - a.galleryCount)
  .slice(0, 3);

const title       = category?.seoTitle       ?? `${category.name} Embroidery — MAS Monograms`;
const description = category?.seoDescription ?? `Custom embroidered ${category.name?.toLowerCase() ?? 'items'} from MAS Monograms in St. Matthews, SC. Personalized gifts and monograms.`;

// Filter gallery to items related to this category
const relatedGallery = allGallery.filter(
  (item: any) => item.relatedCategory?.slug?.current === slug,
).slice(0, 9);

const heroImages = (category?.heroImages ?? []).filter((img: any) => img?.asset);

// BreadcrumbList schema: Home > Shop by Item > <Category>. Helps Google render
// a breadcrumb trail in the search result for each category page.
const pageSchemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Shop by Item', url: `${site.url}/shop-by-item` },
    { name: category.name, url: `${site.url}/${slug}` },
  ]),
];
---

<BaseLayout {title} {description} seoImage={category?.seoImage} {siteSettings} schemas={pageSchemas}>

  {/* Hero */}
  <Hero
    backgroundImages={heroImages}
    eyebrow={category?.eyebrow}
    headline={category.name}
    subhead={category?.description}
    primaryCta={{ label: category?.ctaLabel ?? 'Request a Quote', href: '/request-a-quote' }}
    headingId="category-heading"
    size="short"
  />

  {/* Trust items */}
  {(category?.trustItems ?? []).length > 0 && (
    <section class="bg-primary py-m">
      <div class="mx-auto max-w-content px-m">
        <ul class="flex flex-wrap justify-center gap-l list-none">
          {(category.trustItems as string[]).map((item: string) => (
            <li class="text-sm text-white/90 flex items-center gap-xs">
              <span class="text-white/50" aria-hidden="true">✦</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* Gallery — items in this category */}
  {relatedGallery.length > 0 && (
    <section class="py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <h2 class="font-display text-h2 text-foreground text-center mb-l" data-reveal>
          {category.name} Gallery
        </h2>
        <div class="columns-2 sm:columns-3 lg:columns-4 gap-m space-y-m">
          {relatedGallery.map((item: any) => (
            item.image?.asset && (
              <div class="break-inside-avoid rounded-xl overflow-hidden p-1 bg-secondary">
                <div class="overflow-hidden rounded-[calc(var(--radius-xl)-0.25rem)]">
                  <SanityImage
                    source={item.image}
                    width={400}
                    sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                    class="w-full h-auto"
                  />
                </div>
              </div>
            )
          ))}
        </div>
        {/* Photo → quote bridge: turn "I like this" into an action, with the
            item type already pre-filled on the quote form. */}
        <div class="mt-l flex justify-center" data-reveal>
          <CtaLink
            cta={{ label: `Request something like this`, href: `/request-a-quote?item=${slug}` }}
            variant="primary"
          />
        </div>
      </div>
    </section>
  )}

  {/* Explore Other Items — cross-sell */}
  {otherCategories.length > 0 && (
    <section class="bg-tertiary py-section-lg">
      <div class="mx-auto max-w-content px-m">
        <h2 class="font-display text-h2 text-foreground text-center mb-l" data-reveal>
          Explore Other Items
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-m max-w-3xl mx-auto" data-stagger-grid>
          {otherCategories.map((cat: any) => (
            <CategoryCard name={cat.name} slug={cat.slug?.current ?? ''} cardImage={cat.cardImage} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBanner
    ctaLabel={category?.ctaLabel ?? 'Request a Quote'}
    ctaHref="/request-a-quote"
  />
</BaseLayout>
