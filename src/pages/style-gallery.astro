---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SanityImage from '@/components/SanityImage.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import CtaLink from '@/components/CtaLink.astro';
import { getSiteSettings, getStyleGalleryPage, getAllGalleryItems } from '@/lib/queries';

const [siteSettings, page, items] = await Promise.all([
  getSiteSettings(),
  getStyleGalleryPage(),
  getAllGalleryItems(),
]);

const title       = page?.seoTitle       ?? 'Style Gallery — MAS Monograms';
const description = page?.seoDescription ?? 'Browse the MAS Monograms photo gallery for inspiration — see real embroidery samples across fonts, items, and color combinations.';

// ─── Tag normalisation ──────────────────────────────────────────────────────
// Two tags mean "appliqué" — canonicalise the accented one so it filters as
// one. Meta tags describe the PHOTO, not the work, so they never become
// filters (and are stripped from data-tags so they can't match anything).
const META_TAGS = new Set(['closeup', 'customer-photo']);
const TAG_ALIASES: Record<string, string> = { 'appliqué': 'applique' };

function normalizeTag(tag: string): string {
  return TAG_ALIASES[tag] ?? tag;
}

// Per-item cleaned tag list (aliased + meta stripped + de-duped). Used both for
// the count map below and for each card's data-tags attribute, so the
// client-side filter matches on the same canonical set the pills use.
function cleanTags(raw: unknown): string[] {
  if (!Array.isArray(raw)) return [];
  const out: string[] = [];
  for (const t of raw) {
    if (typeof t !== 'string') continue;
    const n = normalizeTag(t);
    if (META_TAGS.has(n)) continue;
    if (!out.includes(n)) out.push(n);
  }
  return out;
}

// Count how many photos carry each (canonical, non-meta) tag.
const tagCounts = new Map<string, number>();
for (const item of items as any[]) {
  for (const t of cleanTags(item.tags)) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}

const presentTags = new Set(tagCounts.keys());

// Order a list of tags by descending photo count (ties broken alphabetically),
// keeping only tags that actually occur — never surface a dead-end filter.
function orderPresent(tags: string[]): string[] {
  return tags
    .filter((t) => presentTags.has(t))
    .sort((a, b) => (tagCounts.get(b)! - tagCounts.get(a)!) || a.localeCompare(b));
}

function titleCase(slug: string): string {
  return slug
    .split('-')
    .map((w) => (w ? w[0].toUpperCase() + w.slice(1) : w))
    .join(' ');
}

// ─── Build the rendered groups ──────────────────────────────────────────────
type RenderGroup = { label: string; tags: string[] };

const configuredGroups: Array<{ groupLabel?: string; tags?: string[] }> =
  page?.filterGroups ?? [];

let renderGroups: RenderGroup[] = [];

if (configuredGroups.length > 0) {
  // Curated taxonomy: each group shows only its present tags, most photos first.
  renderGroups = configuredGroups
    .map((g) => ({
      label: g.groupLabel ?? 'Filters',
      tags: orderPresent((g.tags ?? []).map(normalizeTag)),
    }))
    .filter((g) => g.tags.length > 0);
} else {
  // Fallback (pre-seed): one "Filters" group of every present tag. Still drops
  // meta tags and merges the dup, so it never regresses to the raw pill wall.
  const allPresent = orderPresent(Array.from(presentTags));
  if (allPresent.length > 0) {
    renderGroups = [{ label: 'Filters', tags: allPresent }];
  }
}

const hasFilters = renderGroups.length > 0;
const MAX_VISIBLE = 8; // tags shown before the "+ more" toggle kicks in

const filterAllLabel = page?.filterAllLabel ?? 'All';
---

<BaseLayout {title} {description} seoImage={page?.seoImage} {siteSettings}>

  {/* Hero */}
  <section class="bg-tertiary py-section-lg">
    <div class="mx-auto max-w-content px-m text-center" data-reveal>
      {page?.heroEyebrow && (
        <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.heroEyebrow}</p>
      )}
      <h1 class="font-display text-h1 text-foreground leading-headline-tight mb-m">
        {page?.heroHeadline ?? 'Style Gallery'}
      </h1>
      {page?.heroSubhead && (
        <p class="text-[var(--color-text-secondary)] max-w-2xl mx-auto">{page.heroSubhead}</p>
      )}
      {/* Photo → quote bridge: a visible path from browsing inspiration to
          starting a real request, right under the intro. */}
      <div class="mt-l flex justify-center">
        <CtaLink
          cta={{ label: 'Start your quote', href: '/request-a-quote' }}
          variant="primary"
        />
      </div>
    </div>
  </section>

  {/* Gallery with client-side filter */}
  <section class="py-section-lg">
    <div class="mx-auto max-w-content px-m">

      {/* Grouped filters. On mobile the whole block collapses behind one
          "Filter" disclosure so photos lead on first paint; on sm+ it's
          always open. The panel is rendered `open` so it reserves layout
          height — a closed disclosure collapses to zero height even when its
          content is force-shown via CSS, which would overlap the grid. The
          init script closes it on mobile so it collapses behind the summary. */}
      {hasFilters && (
        <details class="gallery-filter-panel group mb-l" id="gallery-filters-panel" open>
          <summary
            class="flex sm:hidden items-center justify-center gap-xs cursor-pointer list-none text-xs uppercase tracking-eyebrow text-link px-m py-xs rounded-full border border-border w-max mx-auto mb-m select-none"
          >
            <span>{filterAllLabel === 'All' ? 'Filter' : filterAllLabel}</span>
            <svg class="w-3 h-3 transition-transform group-open:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>

          <div id="gallery-filters" role="group" aria-label="Filter gallery">
            {/* "All" reset button */}
            <div class="flex justify-center mb-m">
              <button
                type="button"
                data-filter="all"
                class="gallery-filter active-filter text-xs uppercase tracking-eyebrow px-m py-xs rounded-full border border-primary bg-primary text-white transition-colors"
                aria-pressed="true"
              >
                {filterAllLabel}
              </button>
            </div>

            {/* One labelled block per group */}
            <div class="space-y-m">
              {renderGroups.map((grp) => {
                const visible = grp.tags.slice(0, MAX_VISIBLE);
                const overflow = grp.tags.slice(MAX_VISIBLE);
                return (
                  <div class="text-center">
                    <p class="text-[var(--color-text-tertiary)] text-xs uppercase tracking-eyebrow mb-s">{grp.label}</p>
                    <div class="flex flex-wrap gap-s justify-center">
                      {visible.map((tag) => (
                        <button
                          type="button"
                          data-filter={tag}
                          class="gallery-filter text-xs uppercase tracking-eyebrow px-m py-xs rounded-full border border-border text-[var(--color-text-secondary)] hover:border-primary hover:text-link transition-colors"
                          aria-pressed="false"
                        >
                          {titleCase(tag)}
                        </button>
                      ))}
                      {overflow.length > 0 && (
                        <details class="more-tags group/more inline">
                          <summary
                            class="gallery-more-toggle inline-flex items-center text-xs uppercase tracking-eyebrow px-m py-xs rounded-full border border-border text-[var(--color-text-tertiary)] hover:border-primary hover:text-link transition-colors cursor-pointer list-none select-none"
                          >
                            <span class="group-open/more:hidden">+ {overflow.length} more</span>
                            <span class="hidden group-open/more:inline">Less</span>
                          </summary>
                          <span class="contents">
                            {overflow.map((tag) => (
                              <button
                                type="button"
                                data-filter={tag}
                                class="gallery-filter text-xs uppercase tracking-eyebrow px-m py-xs rounded-full border border-border text-[var(--color-text-secondary)] hover:border-primary hover:text-link transition-colors ml-s"
                                aria-pressed="false"
                              >
                                {titleCase(tag)}
                              </button>
                            ))}
                          </span>
                        </details>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </details>
      )}

      {items.length > 0 ? (
        <div class="columns-2 sm:columns-3 lg:columns-4 gap-m space-y-m" id="gallery-grid">
          {(items as any[]).map((item) => (
            <div
              class="gallery-item group break-inside-avoid rounded-xl overflow-hidden p-1 bg-secondary"
              data-tags={JSON.stringify(cleanTags(item.tags))}
            >
              {item.image?.asset && (
                <div class="relative overflow-hidden rounded-[calc(var(--radius-xl)-0.25rem)] img-zoom">
                  <SanityImage
                    source={item.image}
                    width={400}
                    sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                    class="w-full h-auto object-cover"
                  />
                  <div class="img-tint" aria-hidden="true"></div>
                </div>
              )}
              {(item.relatedCategory?.name || item.relatedFont?.name) && (
                <div class="px-s py-xs">
                  {item.relatedCategory?.name && (
                    <p class="text-xs text-[var(--color-text-secondary)]">{item.relatedCategory.name}</p>
                  )}
                  {item.relatedFont?.name && (
                    <p class="text-xs text-[var(--color-text-tertiary)] italic">{item.relatedFont.name} font</p>
                  )}
                  {/* Per-photo quote bridge — only when we can deep-link the
                      item type into the form. */}
                  {item.relatedCategory?.slug?.current && (
                    <a
                      href={`/request-a-quote?item=${item.relatedCategory.slug.current}`}
                      class="mt-xs inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link hover:underline"
                    >
                      Request this <span aria-hidden="true">→</span>
                    </a>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-[var(--color-text-secondary)] py-l">
          {page?.emptyStateMessage ?? 'Gallery photos coming soon.'}
        </p>
      )}
      <div id="gallery-empty" class="hidden text-center py-l">
        <p class="text-[var(--color-text-secondary)]">
          {page?.emptyStateMessage ?? 'No items match that filter.'}
        </p>
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow={page?.ctaEyebrow}
    headline={page?.ctaHeadline}
    subhead={page?.ctaSubhead}
    ctaLabel={page?.ctaLabel}
    ctaHref={page?.ctaHref}
  />
</BaseLayout>

<style>
  /* Hide the default disclosure triangle on our filter summaries. */
  .gallery-filter-panel > summary::-webkit-details-marker,
  .more-tags > summary::-webkit-details-marker { display: none; }
  /* Smooth the fade back IN when a tile stops being filtered out (the tile is a
     plain div, so it has no default transition). The fade OUT is driven by
     `.is-filtered-out` in globals.css. */
  .gallery-item {
    transition: opacity 360ms cubic-bezier(0.16, 1, 0.3, 1),
                transform 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-item { transition: none; }
  }
  /* Keep the filter panel open on sm+ regardless of the <details> open attr. */
  @media (min-width: 640px) {
    .gallery-filter-panel > #gallery-filters { display: block !important; }
    .gallery-filter-panel > summary { display: none; }
  }
</style>

<script>
  function initGalleryFilter() {
    const filters = document.querySelectorAll<HTMLButtonElement>('.gallery-filter');
    const items = document.querySelectorAll<HTMLElement>('.gallery-item');
    const emptyMsg = document.getElementById('gallery-empty');
    if (!filters.length || !items.length) return;

    // The panel is rendered `open` (so it reserves height on desktop, where the
    // summary is hidden). On mobile, collapse it so photos lead on first paint;
    // the summary then toggles it. Desktop keeps it open — CSS hides the summary.
    const panel = document.getElementById('gallery-filters-panel');
    if (panel && window.matchMedia('(max-width: 639px)').matches) {
      panel.removeAttribute('open');
    }

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.filter ?? 'all';

        // Update button states across every group.
        filters.forEach((b) => {
          const active = b.dataset.filter === tag;
          b.setAttribute('aria-pressed', String(active));
          b.classList.toggle('active-filter', active);
          b.classList.toggle('bg-primary', active);
          b.classList.toggle('text-white', active);
          b.classList.toggle('border-primary', active);
          b.classList.toggle('text-[var(--color-text-secondary)]', !active);
        });

        // Filter items with a fade instead of a hard pop. `display` can't be
        // transitioned, so to HIDE we add `.is-filtered-out` (opacity + scale
        // fade, 360ms in globals.css) first, then set `display:none` after the
        // transition so the masonry `columns` layout reflows. To SHOW we clear
        // `display` first, then drop `.is-filtered-out` on the next frame so the
        // tile fades back in. Honour reduced-motion by skipping the delay.
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const HIDE_MS = 360;
        let visible = 0;
        items.forEach((item) => {
          const tags: string[] = JSON.parse(item.dataset.tags ?? '[]');
          const show = tag === 'all' || tags.includes(tag);

          if (show) {
            visible++;
            item.style.display = '';
            if (reduceMotion) {
              item.classList.remove('is-filtered-out');
            } else {
              // Fade back in on the next frame so the display change lands first.
              requestAnimationFrame(() => {
                requestAnimationFrame(() => item.classList.remove('is-filtered-out'));
              });
            }
          } else {
            if (item.classList.contains('is-filtered-out') && item.style.display === 'none') {
              return; // already hidden
            }
            if (reduceMotion) {
              item.classList.add('is-filtered-out');
              item.style.display = 'none';
            } else {
              item.classList.add('is-filtered-out');
              window.setTimeout(() => {
                // Only collapse if it's still filtered out (guards against a
                // rapid re-select flipping it back to visible mid-transition).
                if (item.classList.contains('is-filtered-out')) {
                  item.style.display = 'none';
                }
              }, HIDE_MS);
            }
          }
        });
        if (emptyMsg) emptyMsg.classList.toggle('hidden', visible > 0);
      });
    });
  }
  initGalleryFilter();
  document.addEventListener('astro:page-load', initGalleryFilter);
</script>
