---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SanityImage from '@/components/SanityImage.astro';
import PortableText from '@/components/PortableText';
import {
  getSiteSettings,
  getRequestAQuotePage,
  getAllItemCategories,
  getAllFonts,
} from '@/lib/queries';

const [siteSettings, page, itemCategories, fonts] = await Promise.all([
  getSiteSettings(),
  getRequestAQuotePage(),
  getAllItemCategories(),
  getAllFonts(),
]);

// ── Item-type dropdown options ──────────────────────────────────────────────
// Real item categories from Sanity, followed by a low-friction "not sure"
// escape so a required field never blocks a hesitant visitor. Each option
// carries its slug (data-slug) so the ?item=<slug> deep-link can match by slug
// — the visible option value is the display name ("Hats & Caps"), which the
// slug ("hats-caps") can't be reconstructed into by humanizing alone.
const itemTypeOptions: Array<{ name: string; slug: string }> = [
  ...(itemCategories ?? [])
    .map((c: { name?: string; slug?: { current?: string } }) => ({
      name: c?.name ?? '',
      slug: c?.slug?.current ?? '',
    }))
    .filter((o: { name: string }) => Boolean(o.name)),
  { name: 'Not sure — recommend for me', slug: '' },
];

// ── Font dropdown options ───────────────────────────────────────────────────
// Real embroidery fonts from Sanity (name only), plus "Other" and a "recommend"
// escape. Kept as bare names so the ?font= deep-link param can match exactly.
const fontNames: string[] = (fonts ?? [])
  .map((f: { name?: string }) => f?.name)
  .filter((n: string | undefined): n is string => Boolean(n));
const FONT_OTHER = 'Other';
const FONT_RECOMMEND = 'Recommend for me';
const fontOptions: string[] = [...fontNames, FONT_OTHER, FONT_RECOMMEND];

// ── Fixed domain option lists ───────────────────────────────────────────────
// These are standard embroidery choices unlikely to change, so they live here
// as clearly-commented const arrays rather than in Sanity. If Mary Ann ever
// needs to edit them, promote each list to an array field on the
// `requestAQuotePage` schema (mirroring `referralOptions`) and read it via
// getRequestAQuotePage() — the render loop below won't need to change.
const ownershipOptions: string[] = [
  'I have the item',
  'Please source it for me',
  'Not sure yet',
];
const monogramStyleOptions: string[] = [
  'Three-letter monogram',
  'Name or word',
  'Custom text',
  'Appliqué',
  'Custom embroidery',
  'Recommend for me',
];
const placementOptions: string[] = [
  'Center chest',
  'Upper-left chest',
  'Back',
  'Cuff or sleeve',
  'Corner',
  'Hat brim',
  'Full front',
  'Other',
  'Recommend for me',
];
const sizeOptions: string[] = [
  'Small (under 2")',
  'Standard (2–4")',
  'Large (4–6")',
  'Extra large (6"+)',
  'Recommend for me',
];
const threadCountOptions: string[] = ['1', '2', '3 or more', 'Not sure'];
// "How did you hear about us?" — optional, so no "recommend" escape needed.
const howHeardOptions: string[] = [
  'Google',
  'Instagram',
  'Facebook',
  'Referral',
  'Returning customer',
  'Other',
];

const title       = page?.seoTitle       ?? 'Request a Quote — MAS Monograms';
const description = page?.seoDescription ?? "Request a custom embroidery quote from MAS Monograms. Tell Mary Ann what you need and she'll get back to you within 1–2 business days.";

const L = {
  orderInfoHeading:      page?.orderInfoHeading          ?? 'About Your Order',
  personalInfoHeading:   page?.personalInfoHeading       ?? 'Your Information',
  attachmentsHeading:    page?.attachmentsHeading        ?? 'Photos (Optional)',
  additionalHeading:     page?.additionalHeading         ?? 'Anything Else?',
  itemTypeLabel:         page?.itemTypeLabel             ?? 'What type of item?',
  itemTypePlaceholder:   page?.itemTypePlaceholder       ?? 'e.g. bath towels, a tote bag, onesies…',
  itemTypeHelp:          page?.itemTypeHelp              ?? null,
  itemTypeError:         page?.itemTypeError             ?? 'Please choose an item type.',
  ownershipLabel:        page?.ownershipLabel            ?? 'Do you own the item?',
  ownershipHelp:         page?.ownershipHelp             ?? null,
  ownershipError:        page?.ownershipError            ?? 'Please let us know about the item.',
  itemDescriptionLabel:  page?.itemDescriptionLabel      ?? 'Item description',
  itemDescriptionPlaceholder: page?.itemDescriptionPlaceholder ?? 'Brand, color, fabric, size…',
  itemDescriptionHelp:   page?.itemDescriptionHelp       ?? null,
  monogramStyleLabel:    page?.monogramStyleLabel        ?? 'Monogram style',
  monogramStyleHelp:     page?.monogramStyleHelp         ?? null,
  monogramStyleError:    page?.monogramStyleError        ?? 'Please choose a monogram style.',
  placementSelectLabel:  page?.placementSelectLabel      ?? 'Placement on item',
  placementSelectHelp:   page?.placementSelectHelp       ?? null,
  placementSelectError:  page?.placementSelectError      ?? 'Please choose a placement.',
  sizeLabel:             page?.sizeLabel                 ?? 'Approximate size',
  sizeHelp:              page?.sizeHelp                  ?? null,
  sizeError:             page?.sizeError                 ?? 'Please choose an approximate size.',
  threadCountLabel:      page?.threadCountLabel          ?? 'Number of thread colors',
  threadCountHelp:       page?.threadCountHelp           ?? null,
  threadCountError:      page?.threadCountError          ?? 'Please choose the number of thread colors.',
  rushLabel:             page?.rushLabel                 ?? 'I need this rushed (a rush fee may apply)',
  rushHelp:              page?.rushHelp                  ?? null,
  quantityLabel:         page?.quantityLabel             ?? 'Quantity',
  quantityPlaceholder:   page?.quantityPlaceholder       ?? 'e.g. 2',
  quantityHelp:          page?.quantityHelp              ?? null,
  personalizationLabel:  page?.personalizationLabel      ?? 'Personalization Details',
  personalizationPlaceholder: page?.personalizationPlaceholder ?? 'Names, initials, dates, monogram style…',
  personalizationHelp:   page?.personalizationHelp       ?? null,
  personalizationError:  page?.personalizationError      ?? 'Please describe your personalization.',
  fontLabel:             page?.fontPreferenceLabel       ?? 'Font Preference (Optional)',
  fontHelp:              page?.fontPreferenceHelp        ?? 'Not sure? Browse the Font Guide.',
  threadLabel:           page?.threadColorLabel          ?? 'Thread Color Preference (Optional)',
  threadPlaceholder:     page?.threadColorPlaceholder    ?? 'Color name or code, or "I trust your judgment"',
  threadHelp:            page?.threadColorHelp           ?? 'Browse the Thread Color Chart for reference.',
  neededByLabel:         page?.neededByLabel             ?? 'Date Needed By (Optional)',
  neededByHelp:          page?.neededByHelp              ?? 'Rush orders may incur additional charges.',
  giftLabel:             page?.giftLabel                 ?? 'Is this a gift?',
  giftOptionYes:         page?.giftOptionYes             ?? 'Yes — please keep it a surprise!',
  giftOptionNo:          page?.giftOptionNo              ?? 'No',
  nameLabel:             page?.nameLabel                 ?? 'Your Name',
  namePlaceholder:       page?.namePlaceholder           ?? 'First and last name',
  nameError:             page?.nameError                 ?? 'Please enter your name.',
  emailLabel:            page?.emailLabel                ?? 'Email Address',
  emailPlaceholder:      page?.emailPlaceholder         ?? 'you@example.com',
  emailError:            page?.emailError               ?? 'Please enter a valid email.',
  phoneLabel:            page?.phoneLabel               ?? 'Phone Number',
  phonePlaceholder:      page?.phonePlaceholder         ?? '(843) 555-0100',
  phoneError:            page?.phoneError               ?? 'Please enter a phone number.',
  referralLabel:         page?.referralLabel            ?? 'How did you hear about us?',
  referralOptions:       (page?.referralOptions ?? howHeardOptions) as string[],
  attachmentsHelp:       page?.attachmentsHelp          ?? 'Upload up to 5 photos (JPG, PNG, WEBP). Max 5 MB each.',
  attachmentsError:      page?.attachmentsError         ?? 'Each file must be under 5 MB.',
  notesLabel:            page?.notesLabel               ?? 'Additional Notes',
  notesPlaceholder:      page?.notesPlaceholder         ?? 'Anything else Mary Ann should know?',
  submitLabel:           page?.submitLabel              ?? 'Send My Quote Request',
  submittingLabel:       page?.submittingLabel          ?? 'Sending…',
  privacyNote:           page?.privacyNote              ?? null,
  turnaroundCallout:     page?.turnaroundCallout        ?? null,
  requiredFieldNote:     page?.requiredFieldNote        ?? 'Fields marked * are required.',
};

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<BaseLayout {title} {description} seoImage={page?.seoImage} {siteSettings}>

  {/* Hero */}
  <section class="bg-tertiary py-section-lg">
    <div class="mx-auto max-w-content px-m grid grid-cols-1 lg:grid-cols-2 gap-section-md items-center">
      <div data-reveal>
        {page?.heroEyebrow && (
          <p class="text-xs uppercase tracking-eyebrow text-link mb-s">{page.heroEyebrow}</p>
        )}
        <h1 class="font-display text-h1 text-foreground leading-headline-tight mb-m">
          {page?.heroHeadline ?? 'Request a Custom Quote'}
        </h1>
        {page?.heroSubhead && (
          <p class="text-[var(--color-text-secondary)] max-w-xl">{page.heroSubhead}</p>
        )}
        {page?.heroBody && (
          <div class="text-[var(--color-text-secondary)] mt-m">
            <PortableText client:idle value={page.heroBody} />
          </div>
        )}
        {(page?.heroTrustItems ?? []).length > 0 && (
          <ul class="mt-l space-y-s list-none">
            {(page.heroTrustItems as string[]).map((item: string) => (
              <li class="flex items-start gap-s text-sm text-[var(--color-text-secondary)]">
                <span class="text-primary mt-0.5" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>
        )}
      </div>
      {page?.heroImage?.asset && (
        <div class="rounded-2xl overflow-hidden shadow-xl" data-reveal>
          <SanityImage
            source={page.heroImage}
            width={700}
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="w-full h-auto object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}
    </div>
  </section>

  {/* Form */}
  <section class="py-section-lg">
    <div class="mx-auto max-w-3xl px-m">

      <div id="form-success" class="hidden mb-l p-l bg-primary/10 border border-primary/20 rounded-xl text-primary" role="alert" aria-live="polite">
        <p class="font-semibold">We got it!</p>
        <p class="text-sm">Redirecting you to the confirmation page…</p>
      </div>
      <div id="form-error" class="hidden mb-l p-l bg-red-50 border border-red-200 rounded-xl text-red-800" role="alert" aria-live="polite">
        <p class="font-semibold">Something went wrong.</p>
        <p id="form-error-msg" class="text-sm mt-xs">Please try again or email Mary Ann directly.</p>
      </div>

      <form
        id="quote-form"
        method="POST"
        action="/api/quote"
        enctype="multipart/form-data"
        novalidate
        class="space-y-section-md"
      >

        {L.requiredFieldNote && (
          <p class="text-sm text-[var(--color-text-secondary)]">
            {L.requiredFieldNote}
          </p>
        )}

        {/* ── Order Information ── */}
        <fieldset class="space-y-l">
          <legend class="font-display text-h3 text-foreground mb-m border-b border-border-soft pb-s w-full">
            {L.orderInfoHeading}
          </legend>

          {/* Item type — real categories + a "not sure" escape */}
          <div class="form-field">
            <label for="itemType" class="form-label">
              {L.itemTypeLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <select
              id="itemType" name="itemType"
              required aria-required="true" aria-describedby="itemType-error" class="form-input"
            >
              <option value="">— Select one —</option>
              {itemTypeOptions.map((opt: { name: string; slug: string }) => (
                <option value={opt.name} data-slug={opt.slug}>{opt.name}</option>
              ))}
            </select>
            {L.itemTypeHelp && <p class="form-help">{L.itemTypeHelp}</p>}
            <p id="itemType-error" class="form-error hidden" data-error-for="itemType">{L.itemTypeError}</p>
          </div>

          {/* Do you own the item? */}
          <div class="form-field">
            <p id="ownership-label" class="form-label">
              {L.ownershipLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </p>
            <div
              id="ownership"
              class="flex flex-col gap-s mt-xs"
              role="radiogroup"
              aria-labelledby="ownership-label"
              aria-required="true"
              aria-describedby="ownership-error"
            >
              {ownershipOptions.map((opt: string) => (
                <label class="flex items-center gap-s text-sm cursor-pointer">
                  <input type="radio" name="ownership" value={opt} class="accent-primary" data-required-radio />
                  <span>{opt}</span>
                </label>
              ))}
            </div>
            {L.ownershipHelp && <p class="form-help">{L.ownershipHelp}</p>}
            <p id="ownership-error" class="form-error hidden" data-error-for="ownership">{L.ownershipError}</p>
          </div>

          {/* Item description (optional free text) */}
          <div class="form-field">
            <label for="itemDescription" class="form-label">{L.itemDescriptionLabel}</label>
            <input
              id="itemDescription" name="itemDescription" type="text"
              placeholder={L.itemDescriptionPlaceholder} class="form-input"
            />
            {L.itemDescriptionHelp && <p class="form-help">{L.itemDescriptionHelp}</p>}
          </div>

          <div class="form-field">
            <label for="quantity" class="form-label">{L.quantityLabel}</label>
            <input
              id="quantity" name="quantity" type="number" min="1" inputmode="numeric"
              placeholder={L.quantityPlaceholder} class="form-input w-32"
            />
            {L.quantityHelp && <p class="form-help">{L.quantityHelp}</p>}
          </div>

          <div class="form-field">
            <label for="personalization" class="form-label">
              {L.personalizationLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <textarea
              id="personalization" name="personalization" rows="3"
              placeholder={L.personalizationPlaceholder}
              required aria-required="true" aria-describedby="personalization-error" class="form-input"
            />
            {L.personalizationHelp && <p class="form-help">{L.personalizationHelp}</p>}
            <p id="personalization-error" class="form-error hidden" data-error-for="personalization">{L.personalizationError}</p>
          </div>

          {/* Monogram style */}
          <div class="form-field">
            <label for="monogramStyle" class="form-label">
              {L.monogramStyleLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <select
              id="monogramStyle" name="monogramStyle"
              required aria-required="true" aria-describedby="monogramStyle-error" class="form-input"
            >
              <option value="">— Select one —</option>
              {monogramStyleOptions.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
            {L.monogramStyleHelp && <p class="form-help">{L.monogramStyleHelp}</p>}
            <p id="monogramStyle-error" class="form-error hidden" data-error-for="monogramStyle">{L.monogramStyleError}</p>
          </div>

          {/* Placement on item */}
          <div class="form-field">
            <label for="placement" class="form-label">
              {L.placementSelectLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <select
              id="placement" name="placement"
              required aria-required="true" aria-describedby="placement-error" class="form-input"
            >
              <option value="">— Select one —</option>
              {placementOptions.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
            {L.placementSelectHelp && <p class="form-help">{L.placementSelectHelp}</p>}
            <p id="placement-error" class="form-error hidden" data-error-for="placement">{L.placementSelectError}</p>
          </div>

          {/* Approximate size */}
          <div class="form-field">
            <label for="size" class="form-label">
              {L.sizeLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <select
              id="size" name="size"
              required aria-required="true" aria-describedby="size-error" class="form-input"
            >
              <option value="">— Select one —</option>
              {sizeOptions.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
            {L.sizeHelp && <p class="form-help">{L.sizeHelp}</p>}
            <p id="size-error" class="form-error hidden" data-error-for="size">{L.sizeError}</p>
          </div>

          {/* Number of thread colors */}
          <div class="form-field">
            <label for="threadCount" class="form-label">
              {L.threadCountLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <select
              id="threadCount" name="threadCount"
              required aria-required="true" aria-describedby="threadCount-error" class="form-input w-48"
            >
              <option value="">— Select one —</option>
              {threadCountOptions.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
            {L.threadCountHelp && <p class="form-help">{L.threadCountHelp}</p>}
            <p id="threadCount-error" class="form-error hidden" data-error-for="threadCount">{L.threadCountError}</p>
          </div>

          {/* Font preference — real fonts + Other + Recommend */}
          <div class="form-field">
            <label for="fontPreference" class="form-label">{L.fontLabel}</label>
            <select id="fontPreference" name="fontPreference" class="form-input">
              <option value="">— Select one —</option>
              {fontOptions.map((opt: string) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
            {L.fontHelp && (
              <p class="form-help">
                {L.fontHelp}
                <a href="/font-lettering-guide" class="ml-xs underline text-link hover:text-primary-dark">Font Guide →</a>
              </p>
            )}
          </div>

          <div class="form-field">
            <label for="threadColor" class="form-label">{L.threadLabel}</label>
            <input
              id="threadColor" name="threadColor" type="text"
              placeholder={L.threadPlaceholder} class="form-input"
            />
            {L.threadHelp && (
              <p class="form-help">
                {L.threadHelp}
                <a href="/thread-color-chart" class="ml-xs underline text-link hover:text-primary-dark">Color Chart →</a>
              </p>
            )}
          </div>

          <div class="form-field">
            <label for="neededBy" class="form-label">{L.neededByLabel}</label>
            <input id="neededBy" name="neededBy" type="date" class="form-input w-48" />
            {L.neededByHelp && <p class="form-help">{L.neededByHelp}</p>}
          </div>

          {/* Rush turnaround */}
          <div class="form-field">
            <label class="flex items-start gap-s text-sm cursor-pointer">
              <input type="checkbox" name="rush" value="yes" class="accent-primary mt-0.5" />
              <span>{L.rushLabel}</span>
            </label>
            {L.rushHelp && <p class="form-help">{L.rushHelp}</p>}
          </div>

          <div class="form-field">
            <p class="form-label">{L.giftLabel}</p>
            <div class="flex items-center gap-l mt-xs">
              <label class="flex items-center gap-s text-sm cursor-pointer">
                <input type="radio" name="isGift" value="yes" class="accent-primary" />
                <span>{L.giftOptionYes}</span>
              </label>
              <label class="flex items-center gap-s text-sm cursor-pointer">
                <input type="radio" name="isGift" value="no" class="accent-primary" checked />
                <span>{L.giftOptionNo}</span>
              </label>
            </div>
          </div>
        </fieldset>

        {/* ── Personal Info ── */}
        <fieldset class="space-y-l">
          <legend class="font-display text-h3 text-foreground mb-m border-b border-border-soft pb-s w-full">
            {L.personalInfoHeading}
          </legend>

          <div class="form-field">
            <label for="name" class="form-label">
              {L.nameLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <input
              id="name" name="name" type="text"
              autocomplete="name" placeholder={L.namePlaceholder}
              required aria-required="true" aria-describedby="name-error" class="form-input"
            />
            <p id="name-error" class="form-error hidden" data-error-for="name">{L.nameError}</p>
          </div>

          <div class="form-field">
            <label for="email" class="form-label">
              {L.emailLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <input
              id="email" name="email" type="email"
              autocomplete="email" placeholder={L.emailPlaceholder}
              required aria-required="true" aria-describedby="email-error" class="form-input"
            />
            <p id="email-error" class="form-error hidden" data-error-for="email">{L.emailError}</p>
          </div>

          <div class="form-field">
            <label for="phone" class="form-label">
              {L.phoneLabel} <span class="text-[#b91c1c]" aria-hidden="true">*</span>
            </label>
            <input
              id="phone" name="phone" type="tel"
              autocomplete="tel" placeholder={L.phonePlaceholder}
              required aria-required="true" aria-describedby="phone-error" class="form-input w-56"
            />
            <p id="phone-error" class="form-error hidden" data-error-for="phone">{L.phoneError}</p>
          </div>

          {L.referralOptions.length > 0 && (
            <div class="form-field">
              <label for="referral" class="form-label">{L.referralLabel}</label>
              <select id="referral" name="referral" class="form-input">
                <option value="">— Select one —</option>
                {L.referralOptions.map((opt: string) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
            </div>
          )}
        </fieldset>

        {/* ── Photos ── */}
        <fieldset class="space-y-l">
          <legend class="font-display text-h3 text-foreground mb-m border-b border-border-soft pb-s w-full">
            {L.attachmentsHeading}
          </legend>
          <div class="form-field">
            <div id="drop-zone" class="relative border-2 border-dashed border-[#847a63] rounded-xl p-l text-center cursor-pointer hover:border-primary/40 transition-colors">
              <input
                id="attachments" name="attachments" type="file"
                accept=".jpg,.jpeg,.png,.webp" multiple
                class="absolute inset-0 opacity-0 w-full h-full cursor-pointer"
                aria-label={L.attachmentsHeading}
                aria-describedby="attachments-help"
              />
              <p class="text-sm text-[var(--color-text-secondary)]">
                Drag & drop photos here, or <span class="text-link underline">click to browse</span>
              </p>
              <p id="attachments-help" class="text-xs text-[var(--color-text-secondary)] mt-xs">{L.attachmentsHelp}</p>
            </div>
            <ul id="file-list" class="mt-s space-y-xs list-none" aria-live="polite" />
            <p id="attachments-error" class="form-error hidden" data-error-for="attachments">{L.attachmentsError}</p>
          </div>
        </fieldset>

        {/* ── Notes ── */}
        <fieldset>
          <legend class="font-display text-h3 text-foreground mb-m border-b border-border-soft pb-s w-full">
            {L.additionalHeading}
          </legend>
          <div class="form-field">
            <label for="notes" class="form-label">{L.notesLabel}</label>
            <textarea
              id="notes" name="notes" rows="4"
              placeholder={L.notesPlaceholder} class="form-input"
            />
          </div>
        </fieldset>

        {/* Turnstile */}
        {turnstileSiteKey && (
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-callback="onTurnstileSuccess"
            data-theme="light"
          />
        )}

        {/* Turnaround reassurance */}
        {L.turnaroundCallout && (
          <p class="flex items-start gap-s rounded-lg border border-primary/20 bg-primary/10 px-m py-s text-sm font-semibold text-primary">
            <span class="mt-0.5" aria-hidden="true">⏱</span>
            <span>{L.turnaroundCallout}</span>
          </p>
        )}

        {/* Submit */}
        <div>
          <button
            id="submit-btn"
            type="submit"
            data-label={L.submitLabel}
            data-submitting={L.submittingLabel}
            class="w-full sm:w-auto px-l py-m rounded-md bg-[var(--color-rust-cta,#8C3A2E)] hover:bg-[var(--color-rust-cta-hover,#722C22)] text-white text-sm uppercase tracking-eyebrow font-semibold transition-colors press-tactile disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="submit-label">{L.submitLabel}</span>
          </button>
          {L.privacyNote && (
            <p class="mt-m text-xs text-[var(--color-text-secondary)]">{L.privacyNote}</p>
          )}
        </div>

      </form>
    </div>
  </section>
</BaseLayout>

{turnstileSiteKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline />
)}

<script>
  // ── Pre-fill from the home "Preview Your Combination" deep link ──
  // The ComboPreview CTA links here with ?item=&font=&thread=&initials=.
  // item/font now map to <select> options; thread stays free text; initials
  // append to the personalization textarea. Only act when a param is present,
  // and never clobber anything the visitor has already chosen or typed.
  (function prefillFromQuery() {
    const params = new URLSearchParams(window.location.search);
    if (![...params.keys()].length) return;

    // Turn a category slug ("bath-towels") into a friendly label ("Bath Towels").
    const humanize = (slug: string) =>
      slug
        .split(/[-_]/)
        .filter(Boolean)
        .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
        .join(' ');

    // Set a free-text field, but never overwrite existing user input.
    const setTextValue = (id: string, value: string) => {
      const el = document.getElementById(id) as
        | HTMLInputElement
        | HTMLTextAreaElement
        | null;
      if (!el || el.value.trim().length > 0) return;
      el.value = value;
    };

    // Select a <select> option case-insensitively. Optional fallback value is
    // chosen when no option text matches (used for font → "Other").
    const selectOption = (id: string, wanted: string, fallback?: string) => {
      const el = document.getElementById(id) as HTMLSelectElement | null;
      if (!el || el.value.trim().length > 0) return; // don't override a chosen value
      const target = wanted.trim().toLowerCase();
      const match = Array.from(el.options).find(
        (o) => o.value && o.value.trim().toLowerCase() === target,
      );
      if (match) {
        el.value = match.value;
      } else if (fallback) {
        const fb = Array.from(el.options).find((o) => o.value === fallback);
        if (fb) el.value = fb.value;
      }
    };

    const item = params.get('item');
    // The deep link passes a category slug ("hats-caps"); options are labelled by
    // display name ("Hats & Caps") but carry data-slug. Match the slug first,
    // then fall back to the humanized / raw text for older links.
    if (item) {
      const el = document.getElementById('itemType') as HTMLSelectElement | null;
      if (el && el.value.trim().length === 0) {
        const slug = item.trim().toLowerCase();
        const humanized = humanize(item).toLowerCase();
        const match = Array.from(el.options).find((o) => {
          const optSlug = (o.getAttribute('data-slug') ?? '').trim().toLowerCase();
          const optText = o.value.trim().toLowerCase();
          return (optSlug && optSlug === slug) || optText === humanized || optText === slug;
        });
        if (match) el.value = match.value;
      }
    }

    const font = params.get('font');
    if (font) selectOption('fontPreference', font, 'Other');

    const thread = params.get('thread');
    if (thread) setTextValue('threadColor', thread);

    const initials = params.get('initials');
    if (initials) {
      const field = document.getElementById('personalization') as
        | HTMLTextAreaElement
        | null;
      if (field) {
        const line = `Initials: ${initials}`;
        field.value = field.value.trim().length > 0
          ? `${field.value.trim()}\n${line}`
          : line;
      }
    }
  })();

  let turnstileToken = '';
  (window as any).onTurnstileSuccess = (token: string) => { turnstileToken = token; };

  const attachmentsInput = document.getElementById('attachments') as HTMLInputElement | null;
  const fileList         = document.getElementById('file-list') as HTMLUListElement | null;
  const fileErrorEl      = document.querySelector('[data-error-for="attachments"]') as HTMLElement | null;
  const MAX_FILE_BYTES   = 5 * 1024 * 1024;

  function renderFileList() {
    if (!fileList || !attachmentsInput) return;
    while (fileList.firstChild) fileList.removeChild(fileList.firstChild);

    let hasOversized = false;
    Array.from(attachmentsInput.files ?? []).forEach((file) => {
      const oversized = file.size > MAX_FILE_BYTES;
      if (oversized) hasOversized = true;

      const li   = document.createElement('li');
      const nameSpan = document.createElement('span');
      const sizeSpan = document.createElement('span');
      nameSpan.textContent = file.name;
      sizeSpan.textContent = `${Math.round(file.size / 1024)} KB${oversized ? ' — TOO LARGE' : ''}`;
      li.className = `text-xs flex items-center gap-s ${oversized ? 'text-[#b91c1c]' : 'text-[var(--color-text-secondary)]'}`;
      li.appendChild(nameSpan);
      li.appendChild(sizeSpan);
      fileList.appendChild(li);
    });

    fileErrorEl?.classList.toggle('hidden', !hasOversized);
  }

  attachmentsInput?.addEventListener('change', renderFileList);

  const form        = document.getElementById('quote-form') as HTMLFormElement | null;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label') as HTMLElement | null;
  const successEl   = document.getElementById('form-success') as HTMLElement | null;
  const errorEl     = document.getElementById('form-error') as HTMLElement | null;
  const errorMsgEl  = document.getElementById('form-error-msg') as HTMLElement | null;

  function setFieldError(fieldId: string, visible: boolean) {
    const field = document.getElementById(fieldId) as HTMLElement | null;
    const errEl = document.querySelector(`[data-error-for="${fieldId}"]`) as HTMLElement | null;
    errEl?.classList.toggle('hidden', !visible);
    field?.classList.toggle('border-[#b91c1c]', visible);
    if (field) {
      if (visible) field.setAttribute('aria-invalid', 'true');
      else field.removeAttribute('aria-invalid');
    }
  }

  // Clear a field's error as soon as the visitor edits it. Selects fire
  // 'change'; text inputs/textarea fire 'input'. Attaching both is harmless.
  [
    'itemType', 'monogramStyle', 'placement', 'size', 'threadCount',
    'personalization', 'name', 'email', 'phone',
  ].forEach((id) => {
    const el = document.getElementById(id);
    el?.addEventListener('input', () => setFieldError(id, false));
    el?.addEventListener('change', () => setFieldError(id, false));
  });
  // Ownership is a radio group — clear its error when any option is chosen.
  document.querySelectorAll('input[name="ownership"]').forEach((el) => {
    el.addEventListener('change', () => setFieldError('ownership', false));
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    let valid = true;
    let firstInvalidId: string | null = null;
    // For selects, a non-empty value is valid — "Recommend for me" / "Not sure"
    // are legitimate submitted values, only the "— Select one —" placeholder
    // (value "") is treated as empty.
    const nonEmpty = (v: string) => v.trim().length > 0;
    const required: Array<{ id: string; check: (v: string) => boolean }> = [
      { id: 'itemType',        check: nonEmpty },
      { id: 'monogramStyle',   check: nonEmpty },
      { id: 'placement',       check: nonEmpty },
      { id: 'size',            check: nonEmpty },
      { id: 'threadCount',     check: nonEmpty },
      { id: 'personalization', check: nonEmpty },
      { id: 'name',            check: nonEmpty },
      { id: 'email',           check: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()) },
      { id: 'phone',           check: nonEmpty },
    ];
    required.forEach(({ id, check }) => {
      const el = document.getElementById(id) as
        | HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      const ok = el ? check(el.value) : false;
      setFieldError(id, !ok);
      if (!ok) {
        valid = false;
        if (!firstInvalidId) firstInvalidId = id;
      }
    });

    // Ownership radio group — required. The radiogroup <div> now carries
    // id="ownership", so setFieldError toggles both the error message and
    // aria-invalid on the group itself (mirroring single-input fields).
    const ownershipChecked = !!(form.querySelector(
      'input[name="ownership"]:checked',
    ) as HTMLInputElement | null);
    setFieldError('ownership', !ownershipChecked);
    if (!ownershipChecked) {
      valid = false;
      if (!firstInvalidId) firstInvalidId = 'ownership';
    }

    const files = Array.from(attachmentsInput?.files ?? []);
    if (files.some((f) => f.size > MAX_FILE_BYTES)) {
      valid = false;
      if (!firstInvalidId) firstInvalidId = 'attachments';
    }
    if (!valid) {
      if (firstInvalidId) {
        // Ownership + attachments have no element with a matching id — fall back
        // to the first radio / the file input respectively.
        const target = (
          firstInvalidId === 'ownership'
            ? form.querySelector('input[name="ownership"]')
            : document.getElementById(firstInvalidId)
        ) as HTMLElement | null;
        target?.focus();
        target?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    const data = new FormData(form);
    if (turnstileToken) data.set('cf-turnstile-response', turnstileToken);

    if (submitBtn)   submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = submitBtn?.dataset.submitting ?? 'Sending…';
    errorEl?.classList.add('hidden');

    try {
      const res = await fetch('/api/quote', { method: 'POST', body: data });
      if (res.redirected || res.status === 303) {
        const dest = res.redirected ? res.url : (res.headers.get('Location') ?? '/thank-you');
        successEl?.classList.remove('hidden');
        setTimeout(() => { window.location.href = dest; }, 1200);
        return;
      }
      if (res.ok) {
        successEl?.classList.remove('hidden');
        setTimeout(() => { window.location.href = '/thank-you'; }, 1200);
      } else {
        const body = await res.json().catch(() => ({}));
        if (errorMsgEl) errorMsgEl.textContent = (body as { error?: string }).error ?? 'An unexpected error occurred.';
        errorEl?.classList.remove('hidden');
        if (submitBtn)   submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = submitBtn?.dataset.label ?? 'Send My Quote Request';
      }
    } catch {
      if (errorMsgEl) errorMsgEl.textContent = 'Network error — please check your connection.';
      errorEl?.classList.remove('hidden');
      if (submitBtn)   submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = submitBtn?.dataset.label ?? 'Send My Quote Request';
    }
  });
</script>

<style>
  @reference "../styles/globals.css";

  .form-label {
    @apply block text-xs uppercase tracking-eyebrow font-semibold text-[var(--color-text-secondary)] mb-xs;
  }
  .form-input {
    /* Interactive controls need a resting border that clears WCAG 1.4.11 (3:1)
       against the Linen page bg, since the border is the only affordance. The
       global --border token (#B7AD99, 1.92:1) is for decorative hairlines and
       is intentionally left alone; here we override to #847a63 (3.68:1 on
       #F4EEE3). Focus ring carries its own indicator: a full-Indigo ring
       detached by a 2px offset (8.16:1), not a faint /30 tint. */
    @apply block w-full rounded-md border border-[#847a63] bg-background px-m py-s text-sm text-foreground
           focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-2
           focus:ring-offset-[var(--background)] focus:border-primary transition-colors;
  }
  textarea.form-input { resize: vertical; }
  .form-help  { @apply text-xs text-[var(--color-text-secondary)] mt-xs; }
  .form-error { @apply text-xs text-[#b91c1c] mt-xs; }
  .form-field { @apply flex flex-col; }
</style>
