---
// Safe to edit by hand
// Page hero. Three shapes:
//   1) "bleed" image hero (default; item category pages) — full-bleed Sanity
//      background image with a dark scrim (HeroBackground.astro), h1 + subhead
//      + CTAs overlaid.
//   2) "split" image hero (layout="split"; Home) — a contained two-column band
//      on Linen: text + CTAs on one side, ONE photo in a hoop-ring frame at a
//      bounded portrait size on the other, so the image is never upscaled past
//      its source resolution (the reason a full-bleed hero looked soft with the
//      studio's portrait phone photos).
//   3) "text" hero (no backgroundImage/backgroundImages passed) — clean
//      editorial heading on Parchment with eyebrow + headline + subhead.
//
// The image is the LCP element on the homepage, so it loads eager/high-priority
// in both image shapes. Don't add layout-shift animations to this section.

import HeroBackground from '@/components/HeroBackground.astro';
import SanityImage from '@/components/SanityImage.astro';
import CtaLink from '@/components/CtaLink.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ScriptKicker from '@/components/ScriptKicker.astro';
import { ChevronDown } from 'lucide-react';

interface CtaBlock {
  label?: string;
  href?: string;
  linkType?: 'internal' | 'external' | 'email' | 'phone';
  internalLink?: { _type?: string; slug?: string } | null;
  externalUrl?: string;
  emailAddress?: string;
  phoneNumber?: string;
  openInNewTab?: boolean;
}

interface SanityImageObject {
  asset?: { _ref?: string; _id?: string };
  alt?: string;
  hotspot?: { x: number; y: number; height: number; width: number };
  crop?: { top: number; bottom: number; left: number; right: number };
}

interface Props {
  eyebrow?: string;
  headline: string;
  /** Optional word/phrase rendered in italics immediately after the headline
      (e.g. Home's "Custom Embroidery, Made Just For You" pattern where the
      last word is a Sanity-editable accent). */
  headlineItalicSuffix?: string;
  subhead?: string;
  backgroundImage?: SanityImageObject | null;
  /** Optional list of hero images. 2+ render a cross-fading slideshow; 1 (or
      falling back to backgroundImage) renders a single static image. */
  backgroundImages?: SanityImageObject[] | null;
  primaryCta?: CtaBlock | null;
  secondaryCta?: CtaBlock | null;
  headingId: string;
  /** "tall" = fills the viewport below the header on first load (homepage), "short" = generous but not full screen (interior pages). Ignored by layout="split". */
  size?: 'tall' | 'short';
  /** "bleed" (default) = full-bleed image + dark scrim. "split" = contained
   *  two-column band with the photo in a bounded hoop-frame (no upscaling). */
  layout?: 'bleed' | 'split';
}

const {
  eyebrow,
  headline,
  headlineItalicSuffix,
  subhead,
  backgroundImage,
  backgroundImages,
  primaryCta,
  secondaryCta,
  headingId,
  size = 'short',
  layout = 'bleed',
} = Astro.props as Props;

// Subhead emphasis: parse markdown-style _word_ markers into <em> spans so
// editors can italicize a key word in the Sanity subhead without HTML.
// Example: "Pick the tier that fits _where you are_." → italic on "where you are".
// Falls back to plain text when no markers are present.
function parseSubhead(s?: string): Array<{ type: 'text' | 'em'; value: string }> {
  if (!s) return [];
  const parts = s.split(/(_[^_]+_)/g);
  return parts.map((part) =>
    part.startsWith('_') && part.endsWith('_') && part.length > 2
      ? { type: 'em' as const, value: part.slice(1, -1) }
      : { type: 'text' as const, value: part },
  );
}
const subheadParts = parseSubhead(subhead);

// Prefer the slideshow array; fall back to the single backgroundImage so every
// other page (which only passes backgroundImage) is unaffected.
const heroImageList = (Array.isArray(backgroundImages) ? backgroundImages : []).filter(
  (img) => !!img?.asset,
);
const effectiveImages = heroImageList.length > 0
  ? heroImageList
  : (backgroundImage?.asset ? [backgroundImage] : []);
const hasImage = effectiveImages.length > 0;

// Split hero collage: up to 8 photos across FOUR overlapping, slightly tilted
// rectangular frames arranged as scattered "pinned photos", over a faint
// embroidery hoop (rendered below). Photos are de-duplicated by asset, then
// split into 4 disjoint, contiguous buckets — ONE PER FRAME — so no two
// viewports ever show the same picture at the same time. Each frame cross-fades
// only within its own bucket. Near-duplicate shots sit next to each other in
// the gallery order, so contiguous buckets keep them within a single frame.
const TRI_FRAMES = 4;
const seenAsset = new Set<string>();
const uniqueImages = effectiveImages.filter((img: any) => {
  const ref = img?.asset?._ref || img?.asset?._id;
  if (!ref || seenAsset.has(ref)) return false;
  seenAsset.add(ref);
  return true;
});
const triImages = uniqueImages.slice(0, 8);
const triBase = Math.floor(triImages.length / TRI_FRAMES);
const triRem = triImages.length % TRI_FRAMES;
// Remainder is front-loaded so every bucket is non-empty whenever there are at
// least TRI_FRAMES photos (the render is gated on triImages.length >= 4).
const triBuckets: any[][] = Array.from({ length: TRI_FRAMES }, (_, f) => {
  const start = f * triBase + Math.min(f, triRem);
  const size = triBase + (f < triRem ? 1 : 0);
  return triImages.slice(start, start + size);
});
// Positions are inline styles (Tailwind won't scan class names built in JS).
// Tilt lives in the --rot custom property, applied by .hero-tri-frame in
// globals.css. (The idle-float animation and its --fdur/--fdelay staggering
// were retired in the Direction C motion pass — the tilt is static now.)
const triFrames = [
  { style: 'top:0; left:0; width:56%; z-index:10; --rot:-2deg;',    aspect: 'aspect-[4/3]' },
  { style: 'top:24%; right:0; width:46%; z-index:30; --rot:2.5deg;',  aspect: 'aspect-[3/4]' },
  { style: 'bottom:0; left:14%; width:52%; z-index:20; --rot:-1.5deg;', aspect: 'aspect-[4/3]' },
  { style: 'top:37%; left:0; width:38%; z-index:25; --rot:3deg;',   aspect: 'aspect-[1/1]' },
];

// "tall" (homepage) fills the screen below the sticky header on first load.
// The exact fill height comes from the .hero-fill class plus the measured
// --header-h variable (see the inline script and scoped <style> below).
// "short" stays a generous editorial band for interior pages.
// NOTE: the full-viewport fill only makes sense behind a background image. The
// no-image text fallback uses a bounded band instead (see the !hasImage branch
// below) so it never renders as a screen-height void.
const wrapperHeight =
  size === 'tall'
    ? 'hero-fill'
    : 'min-h-[42svh] md:min-h-[52svh]';

// No-image text hero: a generous editorial band, never the full-viewport fill.
// Used regardless of the `size` prop because a 100svh empty band reads as a void.
const textWrapperHeight = 'min-h-[46svh] md:min-h-[52svh]';
---

{/* Full-viewport home hero plumbing (size="tall" only): measure the sticky
    header into --header-h so the hero fills exactly the space below it, and
    wire the scroll cue to glide past the hero. Runs synchronously so the
    height is set before first paint (no layout shift), then refreshes on
    load, resize, and View Transitions navigations. */}
{size === 'tall' && layout === 'bleed' && (
  <script is:inline>
    (function () {
      function setHeaderH() {
        var header = document.querySelector('header.site-header');
        if (header) {
          document.documentElement.style.setProperty('--header-h', header.offsetHeight + 'px');
        }
      }
      function wireCue() {
        var cue = document.querySelector('[data-scroll-cue]');
        if (!cue || cue.dataset.wired === '1') return;
        cue.dataset.wired = '1';
        cue.addEventListener('click', function () {
          var hero = cue.closest('section');
          if (!hero) return;
          var hh = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-h')) || 0;
          var top = hero.offsetTop + hero.offsetHeight - hh;
          if (window.lenis && typeof window.lenis.scrollTo === 'function') {
            window.lenis.scrollTo(top);
          } else {
            window.scrollTo({ top: top, behavior: 'smooth' });
          }
        });
      }
      setHeaderH();
      wireCue();
      if (!window.__heroLayoutBound) {
        window.__heroLayoutBound = true;
        window.addEventListener('resize', setHeaderH, { passive: true });
        window.addEventListener('load', setHeaderH);
        document.addEventListener('astro:page-load', function () { setHeaderH(); wireCue(); });
      }
    })();
  </script>
)}

{/* Direction C drench: the split hero commits to Heritage Indigo as a full
    surface — linen/paper type on top, gold accents, paper-matted photos.
    Contrast on indigo: Linen text 7.6:1, Linen/85 ≈ 6.4:1, gold eyebrow
    4.84:1 (AA at this size; the gold is reserved for the eyebrow/kicker
    and hairlines — never body copy). */}
{hasImage && layout === 'split' ? (
  <section class="bg-primary" aria-labelledby={headingId}>
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 lg:grid-cols-2 gap-section-md items-center">
      {/* Text column. hero-entry-stagger fades each child up on load (see the
          bleed branch below for the full note); reduced-motion users get the
          final composition instantly. */}
      <div class="hero-entry-stagger max-w-xl">
        {/* Direction C script kicker: the ONE Petemoss moment this page gets
            (gold on indigo — see ScriptKicker.astro for the full rules). */}
        <ScriptKicker text={eyebrow} onDark class="mb-s" />
        <h1 id={headingId} class="font-display text-h1 leading-headline-tight tracking-[-0.02em] text-bg">
          {headline}{headlineItalicSuffix && <>{' '}<em class="italic">{headlineItalicSuffix}</em></>}
        </h1>
        {subhead && (
          <p class="mt-m max-w-xl text-lg text-bg/85">
            {subheadParts.map((part) =>
              part.type === 'em'
                ? <em class="italic font-display text-bg">{part.value}</em>
                : part.value
            )}
          </p>
        )}
        {(primaryCta || secondaryCta) && (
          <div class="mt-l flex flex-wrap gap-s">
            {primaryCta && <CtaLink cta={primaryCta} variant="primary" onDark />}
            {secondaryCta && <CtaLink cta={secondaryCta} variant="secondary" onDark />}
          </div>
        )}
      </div>

      {/* Photo column: four overlapping, slightly tilted rectangular viewports,
          each a fast Ken Burns cross-fade cycling its OWN disjoint bucket of
          gallery photos (so no two frames ever show the same picture), over a
          faint embroidery hoop. Falls back to a single framed image when there
          are fewer than 4 photos. Only the first frame's first photo is the
          eager LCP. */}
      {triImages.length >= 4 ? (
        <div class="relative w-full aspect-[5/6]">
          {/* The brass hoop ring that used to sit behind the collage is gone
              (Direction C): it existed to fill Linen negative space, and on
              the indigo drench it read as mud behind the paper mats. */}
          {triFrames.map((fr, fi) => (
            <div class="hero-tri-frame absolute p-[7px] bg-card rounded-xl shadow-lg" style={fr.style}>
              <div class:list={['relative overflow-hidden rounded-[calc(var(--radius-xl)-7px)]', fr.aspect]} data-hero-tri>
                {triBuckets[fi].map((img: any, i: number) => (
                  <SanityImage
                    source={img}
                    width={640}
                    sizes="(max-width: 1024px) 45vw, 30vw"
                    loading={fi === 0 && i === 0 ? 'eager' : 'lazy'}
                    fetchpriority={fi === 0 && i === 0 ? 'high' : 'low'}
                    quality={78}
                    alt={fi === 0 && i === 0 ? undefined : ''}
                    class={`hero-tri-slide${i === 0 ? ' is-active' : ''}`}
                  />
                ))}
              </div>
              {/* Running-stitch line on the paper mat — claret dashes read as
                  topstitching around each piece (Direction C: the stitch motif
                  is the one decorative system, always in claret). Decorative. */}
              <div class="pointer-events-none absolute inset-[3px] rounded-[calc(var(--radius-xl)-3px)] border-[1.5px] border-dashed border-[#8C3A2E]/55" aria-hidden="true"></div>
            </div>
          ))}
          {/* Handmade seal — a small brass "stamp" pressed onto the bottom-left
              of the collage. Decorative (echoes the eyebrow), so aria-hidden. */}
          <div class="absolute z-40 bottom-[3%] left-[1%] w-[24%] max-w-[6.5rem] rotate-[-8deg]" aria-hidden="true">
            <svg viewBox="0 0 100 100" class="w-full h-auto drop-shadow-md">
              <defs>
                <path id="hero-seal-top" d="M 20,50 A 30,30 0 0 1 80,50" />
                <path id="hero-seal-bot" d="M 81,53 A 31,31 0 0 1 19,53" />
              </defs>
              <circle cx="50" cy="50" r="47" fill="#F4EEE3" stroke="#B98A3E" stroke-width="1.6" />
              <circle cx="50" cy="50" r="41" fill="none" stroke="#B98A3E" stroke-width="0.8" />
              <text fill="#835A24" font-size="10" letter-spacing="1.4" font-weight="700" style="font-family: var(--font-body), sans-serif;">
                <textPath href="#hero-seal-top" startOffset="50%" text-anchor="middle">HANDMADE</textPath>
              </text>
              <text fill="#835A24" font-size="8" letter-spacing="0.6" font-weight="600" style="font-family: var(--font-body), sans-serif;">
                <textPath href="#hero-seal-bot" startOffset="50%" text-anchor="middle">ST. MATTHEWS, SC</textPath>
              </text>
              <text x="50" y="60" text-anchor="middle" fill="#8C3A2E" font-size="30" style="font-family: var(--font-monogram), cursive;">Mas</text>
            </svg>
          </div>
        </div>
      ) : (
        <div class="p-1 bg-card rounded-xl">
          <div class="overflow-hidden rounded-[calc(var(--radius-xl)-0.25rem)] aspect-[4/5]">
            <SanityImage
              source={effectiveImages[0]}
              width={900}
              sizes="(max-width: 1024px) 100vw, 50vw"
              loading="eager"
              fetchpriority="high"
              quality={80}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      )}
    </div>

    {/* Round-robin cross-fade cycler for the three viewports: every ~2s one
        frame advances to its next photo, so something changes often without all
        three flipping at once. Reduced-motion users get static first frames. */}
    {triImages.length >= 4 && (
      <script is:inline>
        (function () {
          function initHeroTri() {
            if (window.__heroTriTimer) { clearInterval(window.__heroTriTimer); window.__heroTriTimer = null; }
            var frames = Array.prototype.slice.call(document.querySelectorAll('[data-hero-tri]'));
            if (!frames.length) return;
            var reduce = false;
            try { reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (_) {}
            if (reduce) return;
            var states = frames.map(function (f) {
              var slides = f.querySelectorAll('.hero-tri-slide');
              var cur = 0;
              for (var i = 0; i < slides.length; i++) { if (slides[i].classList.contains('is-active')) { cur = i; break; } }
              return { slides: slides, cur: cur };
            });
            var turn = 0;
            window.__heroTriTimer = setInterval(function () {
              if (document.hidden) return;
              var s = states[turn % states.length];
              turn++;
              if (s.slides.length < 2) return;
              s.slides[s.cur].classList.remove('is-active');
              s.cur = (s.cur + 1) % s.slides.length;
              s.slides[s.cur].classList.add('is-active');
            }, 2000);
          }
          initHeroTri();
          if (!window.__heroTriBound) {
            window.__heroTriBound = true;
            document.addEventListener('astro:page-load', initHeroTri);
          }
        })();
      </script>
    )}
  </section>
) : hasImage ? (
  <section
    class:list={[
      'relative overflow-hidden bg-accent-dark text-bg flex flex-col justify-end',
      wrapperHeight,
    ]}
    aria-labelledby={headingId}
  >
    {/* Background: single static image or a cross-fading slideshow (2+ images),
        plus the readability overlays. See HeroBackground.astro. */}
    <HeroBackground images={effectiveImages} />

    {/* Content sits at the bottom of the section thanks to justify-end on the
        section itself. Avoids the h-full-on-flex-item brittleness that left
        content floating mid-hero on min-height containers. */}
    <div class="relative mx-auto w-full max-w-content px-m pb-section-lg pt-section-md">
      {/*
        hero-entry-stagger triggers the global page-load fade-up animation
        defined in globals.css. Each direct child of this wrapper fades up
        with a small per-child delay (kicker → h1 → subhead → CTAs).
        Reduced-motion users get the final composition instantly.

        The eyebrow is the page's ONE script kicker (gold — the scrim under it
        is dark, so the on-dark rule applies; see ScriptKicker.astro). The old
        cream hairline went with the tracked-caps treatment.
      */}
      <div class="hero-entry-stagger max-w-3xl">
        <ScriptKicker text={eyebrow} onDark class="mb-s" />
        <h1 id={headingId} class="font-display text-h1 leading-headline-tight tracking-[-0.02em] text-bg">
          {headline}{headlineItalicSuffix && <>{' '}<em class="italic">{headlineItalicSuffix}</em></>}
        </h1>
        {subhead && (
          <p class="mt-m max-w-2xl text-lg text-bg/90">
            {subheadParts.map((part) =>
              part.type === 'em'
                ? <em class="italic font-display text-bg/95">{part.value}</em>
                : part.value
            )}
          </p>
        )}
        {(primaryCta || secondaryCta) && (
          <div class="mt-l flex flex-wrap gap-s">
            {primaryCta && <CtaLink cta={primaryCta} variant="primary" onDark />}
            {secondaryCta && <CtaLink cta={secondaryCta} variant="secondary" onDark />}
          </div>
        )}
      </div>
    </div>

    {/* Soft pulsing scroll cue at the bottom-center of the hero. Tells
        visitors there is more below; clicking it glides past the hero.
        Static under prefers-reduced-motion (see the scoped <style>). */}
    {size === 'tall' && (
      <button
        type="button"
        data-scroll-cue
        aria-label="Scroll down to see more"
        class="scroll-cue absolute bottom-4 left-1/2 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full text-bg/85 hover:text-bg hover:bg-bg/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bg/70"
      >
        <ChevronDown size={28} strokeWidth={1.5} aria-hidden="true" />
      </button>
    )}
  </section>
) : (
  <section class="bg-background" aria-labelledby={headingId}>
    <div class:list={['mx-auto max-w-content px-m py-section-lg flex items-end', textWrapperHeight]}>
      <SectionHeading
        eyebrow={eyebrow}
        headline={headline}
        headlineItalicSuffix={headlineItalicSuffix}
        subhead={subhead}
        headingId={headingId}
        level="h1"
      />
    </div>
  </section>
)}

<style>
  /* Full-viewport home hero. Fill the screen below the sticky header on first
     load. --header-h is measured by the inline script above; the per-breakpoint
     fallback covers the brief pre-measure window and the no-JS case (mobile
     header ~7rem, desktop with the eyebrow strip ~9.5rem). svh keeps the hero
     within the initially-visible viewport on mobile (address bar shown) so it
     never forces an immediate scroll; the vh line is the pre-svh fallback. */
  .hero-fill {
    min-height: calc(100vh - var(--header-h, 7rem));
    min-height: calc(100svh - var(--header-h, 7rem));
  }
  @media (min-width: 1024px) {
    .hero-fill {
      min-height: calc(100vh - var(--header-h, 9.5rem));
      min-height: calc(100svh - var(--header-h, 9.5rem));
    }
  }

  /* Scroll cue: a soft down-bob plus opacity pulse so it reads as "there is
     more below" without shouting. Centered with translateX(-50%) (the keyframe
     re-applies it each step). Reduced-motion users get a static, clearly
     visible chevron instead. */
  .scroll-cue {
    transform: translateX(-50%);
    animation: scroll-cue-bob 2.4s ease-in-out infinite;
  }
  @keyframes scroll-cue-bob {
    0%, 100% { transform: translate(-50%, 0); opacity: 0.55; }
    50%      { transform: translate(-50%, 0.4rem); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue {
      animation: none;
      opacity: 0.85;
      transform: translateX(-50%);
    }
  }
</style>
