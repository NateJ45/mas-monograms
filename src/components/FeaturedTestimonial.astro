---
// Safe to edit by hand
// Large pull-quote at the top of the testimonials section. Renders the testimonial
// with the "featured" flag (or whatever the homepage's featuredTestimonial reference
// points at). Editorial scale, Cormorant Garamond, generous breathing room.
// Optional photo + location render when present (location is a local-trust signal).

import SanityImage from '@/components/SanityImage.astro';

interface SanityImageObject {
  asset?: { _ref?: string; _id?: string };
  alt?: string;
  hotspot?: { x: number; y: number; height: number; width: number };
  crop?: { top: number; bottom: number; left: number; right: number };
}

interface Props {
  testimonial?: {
    quote?: string;
    attribution?: string;
    date?: string;
    source?: string;
    /** sourceType drives the small badge on the featured pull-quote:
        'google' | 'houzz' | 'facebook' | 'direct' | 'other'.
        Renders nothing when absent so existing quotes are unaffected. */
    sourceType?: string;
    location?: string;
    photo?: SanityImageObject | null;
    /** Optional reference to a project case study. When set, the pull-quote
        gets a "See this project →" link beneath the attribution so the
        social proof leads straight into the work that earned it. */
    relatedProject?: {
      title?: string;
      slug?: string;
    } | null;
  } | null;
}

const { testimonial } = Astro.props as Props;

if (!testimonial?.quote) return null;

function formatDate(d?: string): string {
  if (!d) return '';
  const date = new Date(d);
  if (Number.isNaN(date.getTime())) return '';
  return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

const dateLabel = formatDate(testimonial.date);
const sourceLabel = testimonial.source && testimonial.source !== 'Other' ? testimonial.source : '';
const attributionMeta = [testimonial.location, dateLabel, sourceLabel].filter(Boolean).join(' · ');
const hasPhoto = !!testimonial.photo?.asset;

// sourceType badge — same mapping as TestimonialCard.
const SOURCE_LABELS: Record<string, string> = {
  google: 'Google',
  houzz: 'Houzz',
  facebook: 'Facebook',
};
const sourceBadge = testimonial.sourceType ? SOURCE_LABELS[testimonial.sourceType] : undefined;
---

<figure class="mx-auto max-w-3xl text-center relative">
  {/* Opening quote — large editorial display mark in Warm Bronze. Negative
      bottom margin lets the quote text rise into the visual space the mark
      defines, like an editorial pull quote on a magazine spread. */}
  <span
    aria-hidden="true"
    class="block font-display text-[clamp(5rem,10vw,9rem)] leading-[0.8] text-primary/35 select-none mb-[-1.5rem]"
  >
    “
  </span>
  <blockquote class="font-display italic text-[clamp(1.75rem,3vw,2.75rem)] leading-snug text-foreground">
    {testimonial.quote}
  </blockquote>
  {/* Closing quote mark — quieter, off-axis. Read as a deliberate flourish. */}
  <span
    aria-hidden="true"
    class="block font-display text-[clamp(2.5rem,5vw,4rem)] leading-none text-primary/25 select-none mt-s"
  >
    ”
  </span>
  <figcaption class="mt-l flex flex-col items-center gap-s">
    {hasPhoto && (
      <SanityImage
        source={testimonial.photo}
        width={160}
        height={160}
        sizes="80px"
        class="w-20 h-20 rounded-full object-cover ring-2 ring-bg shadow-[0_8px_20px_-12px_rgba(61,61,61,0.35)]"
      />
    )}
    <div>
      <p class="font-display text-h3 text-foreground">{testimonial.attribution}</p>
      {attributionMeta && (
        <p class="mt-xs text-xs uppercase tracking-eyebrow text-[var(--color-text-secondary)]">{attributionMeta}</p>
      )}
      {testimonial.relatedProject?.slug && (
        <p class="mt-m">
          <a
            href={`/portfolio/${testimonial.relatedProject.slug}`}
            class="inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link hover:text-primary-dark transition-colors"
          >
            See this project <span aria-hidden="true">→</span>
          </a>
        </p>
      )}

      {/* Source platform badge — same logic as TestimonialCard. */}
      {sourceBadge && (
        <p class="mt-m inline-flex items-center text-xs text-[var(--color-text-secondary)] bg-muted px-s py-0.5 rounded-full border border-border-soft">
          {sourceBadge}
        </p>
      )}
    </div>
  </figcaption>
</figure>
