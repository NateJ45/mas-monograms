---
// Foundation, edit with care
// Renders a page-builder section array. Maps each block _type to its component
// and OWNS the alternating background cadence for content blocks, so reordering
// can never break the page rhythm (that is why blocks have no color field).
// Self-contained blocks (hero, CTA band, stats, spacer) manage their own surface.
//
// Cadence logic lives in src/lib/sectionCadence.ts and is unit-tested separately.
// This file is thin template glue: it imports classified rows and delegates.
//
// The GROQ query that loads `sections` must project images with imageProjection
// and ctaBlocks with ctaProjection (see sectionsProjection() in queries.ts).
import Hero from '@/components/Hero.astro';
import FinalCta from '@/components/FinalCta.astro';
import StatsRow from '@/components/StatsRow.astro';
import SectionDivider from '@/components/SectionDivider.astro';
import RichTextSection from '@/components/sections/RichTextSection.astro';
import ImageText from '@/components/sections/ImageText.astro';
import GalleryGrid from '@/components/sections/GalleryGrid.astro';
import QuoteBlock from '@/components/sections/QuoteBlock.astro';
import VideoEmbed from '@/components/sections/VideoEmbed.astro';
import FounderSection from '@/components/sections/FounderSection.astro';
import ServicesGridSection from '@/components/sections/ServicesGridSection.astro';
import TestimonialsSection from '@/components/sections/TestimonialsSection.astro';
import StorySection from '@/components/sections/StorySection.astro';
import ValuesSection from '@/components/sections/ValuesSection.astro';
import ProcessSection from '@/components/sections/ProcessSection.astro';
import ServiceAreaSection from '@/components/sections/ServiceAreaSection.astro';
import GuaranteeSection from '@/components/sections/GuaranteeSection.astro';
import FaqSection from '@/components/sections/FaqSection.astro';
import LogoStrip from '@/components/sections/LogoStrip.astro';
import TeamGrid from '@/components/sections/TeamGrid.astro';
import EmbedSection from '@/components/sections/EmbedSection.astro';
import DynamicList from '@/components/sections/DynamicList.astro';
import { classifySections } from '@/lib/sectionCadence';
import type { PageBuilderBlock } from '@/lib/pageBuilder.types';

interface Props {
  sections?: unknown[];
  /** Prefix for generated heading ids, so two renderers on a page do not collide. */
  idPrefix?: string;
}

const { sections = [], idPrefix = 'section' } = Astro.props as Props;
const rows = classifySections<PageBuilderBlock>(sections as PageBuilderBlock[], idPrefix);
---

{rows.map(({ block: s, surface, insertDividerBefore, headingId }) => (
  <>
    {insertDividerBefore && <SectionDivider />}

    {s._type === 'heroSection' ? (
      <Hero
        eyebrow={s.eyebrow}
        headline={s.headline ?? ''}
        subhead={s.subhead}
        backgroundImage={s.backgroundImage}
        primaryCta={s.primaryCta}
        secondaryCta={s.secondaryCta}
        size={s.size ?? 'short'}
        headingId={headingId}
      />
    ) : s._type === 'ctaBandSection' ? (
      <FinalCta
        eyebrow={s.eyebrow}
        headline={s.headline}
        subhead={s.subhead}
        cta={s.cta}
        scriptAccent={s.scriptAccent}
        backgroundImage={s.backgroundImage}
        headingId={headingId}
      />
    ) : s._type === 'statSection' ? (
      <StatsRow
        stats={(s.stats ?? []).filter(
          (x) => typeof x?.number === 'number',
        ) as { number: number; suffix?: string; label: string }[]}
      />
    ) : s._type === 'spacerSection' ? (
      s.variant === 'space' ? (
        <div class="py-section-md" aria-hidden="true"></div>
      ) : (
        <SectionDivider
          variant={
            s.variant === 'line' ? 'line'
            : s.variant === 'dots' ? 'dots'
            : 'ornament'
          }
        />
      )
    ) : s._type === 'richTextSection' ? (
      <RichTextSection
        eyebrow={s.eyebrow}
        heading={s.heading}
        scriptAccent={s.scriptAccent}
        body={s.body}
        width={s.width}
        align={s.align}
        surface={surface ?? 'background'}
        headingId={headingId}
      />
    ) : s._type === 'imageTextSection' ? (
      <ImageText
        image={s.image}
        imageSide={s.imageSide}
        eyebrow={s.eyebrow}
        heading={s.heading}
        body={s.body}
        cta={s.cta}
        surface={surface ?? 'background'}
        headingId={headingId}
      />
    ) : s._type === 'gallerySection' ? (
      <GalleryGrid
        heading={s.heading}
        images={s.images}
        columns={s.columns}
        surface={surface ?? 'background'}
        headingId={headingId}
      />
    ) : s._type === 'quoteSection' ? (
      <QuoteBlock
        quote={s.quote}
        attribution={s.attribution}
        detail={s.detail}
        surface={surface ?? 'background'}
      />
    ) : s._type === 'videoSection' ? (
      <VideoEmbed
        url={s.url}
        heading={s.heading}
        caption={s.caption}
        surface={surface ?? 'background'}
        headingId={headingId}
      />
    ) : s._type === 'founderSection' ? (
      <FounderSection
        portrait={s.portrait}
        eyebrow={s.eyebrow}
        headline={s.headline}
        content={s.content}
        cta={s.cta}
        headingId={headingId}
      />
    ) : s._type === 'servicesGridSection' ? (
      <ServicesGridSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        scriptAccent={s.scriptAccent}
        subhead={s.subhead}
        services={s.services ?? []}
        cta={s.cta}
        footnote={s.footnote}
        variant={s.variant ?? 'grid'}
        headingId={headingId}
      />
    ) : s._type === 'testimonialsSection' ? (
      <TestimonialsSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        scriptAccent={s.scriptAccent}
        subhead={s.subhead}
        featuredQuote={s.featuredQuote}
        testimonialsToShow={s.testimonialsToShow ?? []}
        attribution={s.attribution}
        headingId={headingId}
      />
    ) : s._type === 'storySection' ? (
      <StorySection
        eyebrow={s.eyebrow}
        headline={s.headline}
        content={s.content}
        portrait={s.portrait}
        attribution={s.attribution}
        credentialLine={s.credentialLine}
        serviceAreaLine={s.serviceAreaLine}
        surface={surface ?? 'background'}
        headingId={headingId}
      />
    ) : s._type === 'valuesSection' ? (
      <ValuesSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        points={s.points ?? []}
        headingId={headingId}
      />
    ) : s._type === 'processSection' ? (
      <ProcessSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        subhead={s.subhead}
        steps={s.steps ?? []}
        variant={s.variant ?? 'preview'}
        cta={s.cta}
        headingId={headingId}
      />
    ) : s._type === 'serviceAreaSection' ? (
      <ServiceAreaSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        description={s.description}
        travelFees={s.travelFees ?? []}
        showTravelFees={s.showTravelFees ?? true}
        surface={surface ?? 'background'}
        headingId={headingId}
      />
    ) : s._type === 'guaranteeSection' ? (
      <GuaranteeSection
        text={s.text}
        siteSettingsText={s.siteSettingsText}
        surface={surface ?? 'background'}
      />
    ) : s._type === 'faqSection' ? (
      <FaqSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        subhead={s.subhead}
        items={s.items ?? []}
        cta={s.cta}
        headingId={headingId}
      />
    ) : s._type === 'logoStripSection' ? (
      <LogoStrip
        eyebrow={s.eyebrow}
        headline={s.headline}
        logos={s.logos ?? []}
        layout={s.layout ?? 'row'}
        headingId={headingId}
      />
    ) : s._type === 'teamSection' ? (
      <TeamGrid
        eyebrow={s.eyebrow}
        headline={s.headline}
        subhead={s.subhead}
        members={s.members ?? []}
        headingId={headingId}
      />
    ) : s._type === 'embedSection' ? (
      <EmbedSection
        eyebrow={s.eyebrow}
        headline={s.headline}
        subhead={s.subhead}
        embedUrl={s.embedUrl}
        embedCode={s.embedCode}
        heightHint={s.heightHint ?? 'medium'}
        headingId={headingId}
      />
    ) : s._type === 'dynamicListSection' ? (
      <DynamicList
        eyebrow={s.eyebrow}
        headline={s.headline}
        subhead={s.subhead}
        source={s.source}
        items={s.items ?? []}
        cta={s.cta}
        headingId={headingId}
      />
    ) : (
      // Unknown block type: render nothing, log in dev.
      import.meta.env.DEV && console.warn(`[SectionRenderer] Unknown block type: "${s._type}". Add a mapping in SectionRenderer.astro.`)
    )}
  </>
))}
