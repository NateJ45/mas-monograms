---
// Page-builder block: a centered pull quote / testimonial. Surface comes from
// SectionRenderer. Safe to edit by hand.
interface Props {
  quote?: string;
  attribution?: string;
  detail?: string;
  surface?: 'background' | 'muted';
}

const { quote, attribution, detail, surface = 'background' } = Astro.props as Props;
const bg = surface === 'muted' ? 'bg-muted' : 'bg-background';
---

{quote && (
  <section class:list={['surface-warm', bg]}>
    <div class="mx-auto max-w-content px-m py-section-lg text-center" data-reveal>
      <span class="font-display text-2xl text-link tracking-[0.6em] select-none" aria-hidden="true">✺</span>
      <blockquote class="mt-m mx-auto max-w-3xl font-display text-h3 md:text-h2 leading-snug text-foreground italic">
        {quote}
      </blockquote>
      {(attribution || detail) && (
        <p class="mt-l text-sm uppercase tracking-eyebrow text-[var(--color-text-secondary)]">
          {attribution}{attribution && detail ? ' · ' : ''}{detail}
        </p>
      )}
    </div>
  </section>
)}
