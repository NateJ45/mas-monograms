---
// Page-builder block: a responsive photo grid (2, 3, or 4 columns) with
// optional captions. Surface comes from SectionRenderer. Safe to edit by hand.
import SanityImage from '@/components/SanityImage.astro';
import SectionHeading from '@/components/SectionHeading.astro';

interface GalleryImage {
  asset?: { _ref?: string; _id?: string };
  alt?: string;
  caption?: string;
}

interface Props {
  heading?: string;
  images?: GalleryImage[];
  columns?: number;
  surface?: 'background' | 'muted';
  headingId: string;
}

const { heading, images = [], columns = 3, surface = 'background', headingId } = Astro.props as Props;

const bg = surface === 'muted' ? 'bg-muted' : 'bg-background';
const pics = (images ?? []).filter((i) => i?.asset);
const colClass =
  columns === 2
    ? 'sm:grid-cols-2'
    : columns === 4
      ? 'sm:grid-cols-2 lg:grid-cols-4'
      : 'sm:grid-cols-2 lg:grid-cols-3';
---

{pics.length > 0 && (
  <section
    class={bg}
    aria-labelledby={heading ? headingId : undefined}
    aria-label={!heading ? 'Photo gallery' : undefined}
  >
    <div class="mx-auto max-w-content px-m py-section-lg" data-reveal>
      {heading && (
        <SectionHeading headline={heading} headingId={headingId} align="center" class="mx-auto" />
      )}
      <div class:list={['grid grid-cols-1 gap-m', colClass, heading && 'mt-section-md']} data-stagger-grid>
        {pics.map((img) => (
          <figure class="overflow-hidden rounded-md">
            <SanityImage
              source={img}
              width={800}
              sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 100vw"
              quality={75}
              class="w-full h-auto"
            />
            {img.caption && (
              <figcaption class="mt-xs text-sm text-muted-foreground italic">{img.caption}</figcaption>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>
)}
