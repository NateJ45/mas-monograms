---
// MAS Monograms site footer.
// Layout (Direction C — "The Sampler"):
//   1. Slim indigo brand stripe (seamless under the indigo CTA band above)
//   2. Two-part main block — a brand column (logo + tagline + contact + social)
//      on the left, the navigation link columns on the right
//   3. A running-stitch (dashed brass) divider — the one decorative footer flourish
//   4. Bottom bar: copyright · legal links · site credit
// Link columns are editor-managed via siteSettings.footerColumns (with a
// sensible fallback). Contact + social live in the brand column, so they show
// whether or not custom columns are set.

import { site } from '@/data/site';
import {
  IconBrandInstagram,
  IconBrandFacebook,
  IconBrandPinterest,
  IconLink,
} from '@tabler/icons-react';
import { Mail, Phone, MapPin } from 'lucide-react';
import Logo from './Logo.astro';
import { telHref } from '@/lib/phone';

interface SocialLink { platform?: string; url?: string; label?: string; }
interface FooterColumn { title?: string; links?: Array<{ label?: string; href?: string }>; }

interface Props {
  siteSettings?: {
    title?: string;
    tagline?: string;
    email?: string;
    phone?: string;
    address?: { street?: string; city?: string; state?: string; zip?: string } | null;
    socialLinks?: SocialLink[] | null;
    googleBusinessUrl?: string;
    footerColumns?: FooterColumn[] | null;
    footerCredit?: string;
    footerCreditUrl?: string;
  } | null;
  legalPages?: Array<{ title?: string; slug?: string }> | null;
  /** When false, Clearance links are hidden (nothing on clearance). */
  hasClearance?: boolean;
}

const { siteSettings, legalPages, hasClearance = true } = Astro.props as Props;
const legal = (legalPages ?? []).filter((l) => l?.slug && l?.title);

const brandName     = siteSettings?.title ?? site.name;
const email         = siteSettings?.email ?? '';
const phone         = siteSettings?.phone ?? '';
const address       = siteSettings?.address;
const location      = [address?.city, address?.state].filter(Boolean).join(', ');
const socialLinks   = (siteSettings?.socialLinks ?? []).filter((l) => l?.url);
const siteCredit    = siteSettings?.footerCredit;
const siteCreditUrl = siteSettings?.footerCreditUrl;
const currentYear   = new Date().getFullYear();

// Navigation columns: editor-managed if present, otherwise a sensible default.
// Contact + social are NOT columns here — they live in the brand block.
const sanityColumns = (siteSettings?.footerColumns ?? []).filter(
  (c) => c.title && Array.isArray(c.links) && c.links.length > 0,
);
const FALLBACK_COLUMNS: FooterColumn[] = [
  { title: 'Explore', links: [
    { label: 'How It Works', href: '/how-it-works' },
    { label: 'Pricing', href: '/pricing' },
    { label: 'Shop by Item', href: '/shop-by-item' },
    { label: 'Style Gallery', href: '/style-gallery' },
    { label: 'About', href: '/about' },
  ] },
  { title: 'Resources', links: [
    { label: 'Font & Lettering Guide', href: '/font-lettering-guide' },
    { label: 'Thread Color Chart', href: '/thread-color-chart' },
    ...(hasClearance ? [{ label: 'Clearance', href: '/clearance' }] : []),
  ] },
  { title: 'Get Started', links: [
    { label: 'Request a Quote', href: '/request-a-quote' },
    { label: 'How the process works', href: '/how-it-works' },
  ] },
];
const columns = (sanityColumns.length > 0 ? sanityColumns : FALLBACK_COLUMNS)
  .map((c) => ({
    title: c.title ?? '',
    links: (c.links ?? []).filter((l) => hasClearance || l.href !== '/clearance'),
  }));

function socialIcon(platform: string | undefined) {
  switch (platform) {
    case 'Instagram': return IconBrandInstagram;
    case 'Facebook':  return IconBrandFacebook;
    case 'Pinterest': return IconBrandPinterest;
    default:          return IconLink;
  }
}
---

<footer class="bg-muted text-foreground">
  <div class="h-1 bg-primary" aria-hidden="true"></div>

  <div class="mx-auto max-w-content px-m pt-section-md pb-l">
    <div class="grid grid-cols-1 gap-l gap-y-section-md lg:grid-cols-12">

      {/* ── Brand column ─────────────────────────────────────────────────── */}
      <div class="lg:col-span-4 lg:pr-l text-center sm:text-left">
        <a href="/" aria-label={`${brandName} home`} class="inline-block hover:opacity-80 transition-opacity">
          <Logo variant="ink" class="h-14 w-auto" />
        </a>

        {siteSettings?.tagline && (
          <p class="mt-m max-w-[26rem] mx-auto sm:mx-0 text-sm leading-relaxed text-[var(--color-text-secondary)]">
            {siteSettings.tagline}
          </p>
        )}

        <div class="mt-m flex flex-col items-center sm:items-start gap-xs text-sm">
          {location && (
            <p class="inline-flex items-center gap-xs text-[var(--color-text-secondary)]">
              <MapPin size={14} aria-hidden="true" />
              {location}
            </p>
          )}
          {email && (
            <a href={`mailto:${email}`} class="inline-flex items-center gap-xs text-foreground/85 hover:text-link transition-colors">
              <Mail size={14} aria-hidden="true" />
              {email}
            </a>
          )}
          {phone && (
            <a href={telHref(phone)} class="inline-flex items-center gap-xs text-foreground/85 hover:text-link transition-colors">
              <Phone size={14} aria-hidden="true" />
              {phone}
            </a>
          )}
        </div>

        {socialLinks.length > 0 && (
          <ul class="mt-m flex justify-center sm:justify-start flex-wrap gap-s list-none p-0">
            {socialLinks.map((link) => {
              const Icon = socialIcon(link.platform);
              const ariaLabel = link.label ?? link.platform ?? 'Social link';
              return (
                <li>
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={ariaLabel}
                    class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border text-foreground hover:bg-primary hover:border-primary hover:text-white transition-colors"
                  >
                    <Icon size={18} stroke={1.5} />
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>

      {/* ── Navigation columns ───────────────────────────────────────────── */}
      <nav
        aria-label="Footer"
        class="lg:col-span-8 grid grid-cols-2 gap-l sm:grid-cols-4 text-center sm:text-left"
      >
        {columns.map((col) => (
          <div>
            <p class="text-xs uppercase tracking-eyebrow text-[var(--color-text-secondary)] mb-s font-semibold">
              {col.title}
            </p>
            <ul class="text-sm space-y-2 list-none p-0">
              {col.links.map((link) => (
                <li>
                  <a href={link.href ?? '#'} class="text-foreground/85 hover:text-link transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>
  </div>

  {/* ── Bottom bar. The dashed top border is a running-stitch line — the one
      decorative footer flourish, in decorative brass. On sm+ it's a 3-column
      grid so the legal links sit at the true horizontal centre. ── */}
  <div class="border-t border-dashed border-[#B98A3E]/45">
    <div class="mx-auto max-w-content px-m py-m flex flex-col items-center gap-s text-center text-xs text-[var(--color-text-tertiary)] sm:grid sm:grid-cols-3 sm:items-center sm:gap-m">
      <p class="sm:justify-self-start">© {currentYear} {brandName} · {location || 'St. Matthews, SC'}</p>
      {legal.length > 0 ? (
        <nav aria-label="Legal" class="flex flex-wrap items-center justify-center gap-x-m gap-y-xs sm:justify-self-center">
          {legal.map((lp) => (
            <a href={`/legal/${lp.slug}`} class="hover:text-link transition-colors">{lp.title}</a>
          ))}
        </nav>
      ) : (
        <span class="hidden sm:block" aria-hidden="true"></span>
      )}
      <div class="flex items-center gap-m sm:justify-self-end">
        {siteCredit && (
          siteCreditUrl ? (
            <a
              href={siteCreditUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-2 hover:text-link transition-colors"
            >
              {siteCredit}
            </a>
          ) : (
            <span>{siteCredit}</span>
          )
        )}
      </div>
    </div>
  </div>
</footer>
