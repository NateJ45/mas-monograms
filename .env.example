# Copy this file to `.env` and fill in real values for local dev.
# In production, set PUBLIC_ vars in Cloudflare → Workers → your worker → Settings → Variables.
# Secrets (no PUBLIC_ prefix) are set with:  wrangler secret put SECRET_NAME

# ── Sanity ────────────────────────────────────────────────────────────────────
# Create a project at sanity.io/manage, then paste its project ID here.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2026-05-01

# Read token — bypasses Sanity's anonymous API filter so the full dataset is
# readable at build time. Create at sanity.io/manage → your project → API → Tokens
# with Viewer (read-only) permission.
# In production this is a wrangler secret, NOT a plain env var.
SANITY_API_READ_TOKEN=

# ── Sanity Studio (studio/ directory only) ────────────────────────────────────
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# Your deployed Workers URL used for the Studio live-preview iframe.
SANITY_STUDIO_PREVIEW_URL=https://mas-monograms.com

# ── Quote form Worker ─────────────────────────────────────────────────────────
# These are wrangler secrets in production — do NOT put real values here.
# Set with:  wrangler secret put RESEND_API_KEY
#            wrangler secret put QUOTE_OWNER_EMAIL
#            wrangler secret put TURNSTILE_SECRET_KEY
RESEND_API_KEY=
QUOTE_OWNER_EMAIL=

# ── Cloudflare Turnstile CAPTCHA ──────────────────────────────────────────────
# Get from dash.cloudflare.com → Turnstile → Add site (choose "Invisible").
# PUBLIC_ key is embedded in the quote form HTML at build time.
PUBLIC_TURNSTILE_SITE_KEY=
# Secret key is verified by the Worker. Set with:  wrangler secret put TURNSTILE_SECRET_KEY
TURNSTILE_SECRET_KEY=

# ── Cloudflare Web Analytics ──────────────────────────────────────────────────
# Without this token the analytics beacon is omitted (site still works fine).
PUBLIC_CF_ANALYTICS_TOKEN=
